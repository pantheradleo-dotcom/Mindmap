    // Try to load last active map, fallback to most recent
    const activeId = store.activeId;
    const map = store.maps.find(m=>m.id===activeId) || store.maps.sort((a,b)=>b.ts-a.ts)[0];
    if(!map || !map.nodes || !map.nodes.length) return false;
    currentMapId = map.id;
    nodes = map.nodes; conns = map.conns||[];
    shapes = map.shapes||[]; frames = map.frames||[];
    if(map.theme) applyTheme(map.theme);
    if(map.palette) applyPalette(map.palette);
    rebuildTags();
    return true;
  } catch { return false; }
}

