  return id;
}

function deleteMap(mapId) {
  const store = getMapsStore();
  store.maps = store.maps.filter(m=>m.id!==mapId);
  if(store.activeId===mapId) store.activeId = store.maps.length ? store.maps[store.maps.length-1].id : null;
  saveMapsStore(store);
}

function renameMap(mapId, newName) {
  const store = getMapsStore();
  const m = store.maps.find(m=>m.id===mapId);
  if(m) { m.name=newName; saveMapsStore(store); }
}

function duplicateMap(mapId) {
  const store = getMapsStore();
  const orig = store.maps.find(m=>m.id===mapId);
  if(!orig) return;
  const copy = JSON.parse(JSON.stringify(orig));
  copy.id = uid();
  copy.name = orig.name + ' (copie)';
  copy.ts = Date.now();
  // Remap node IDs to avoid conflicts
  const idMap = {};
  copy.nodes.forEach(n=>{ const newId=uid(); idMap[n.id]=newId; n.id=newId; });
  copy.nodes.forEach(n=>{ if(n.parentId&&idMap[n.parentId]) n.parentId=idMap[n.parentId]; });
  copy.conns.forEach(c=>{ if(idMap[c.s]) c.s=idMap[c.s]; if(idMap[c.t]) c.t=idMap[c.t]; c.id=uid(); });
  store.maps.push(copy);
  saveMapsStore(store);
  return copy.id;
}

