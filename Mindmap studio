// ── MOUSE ─────────────────────────────────────────────────────────────────
let lastHov=0;
// ── CONNECTION HIT-TEST ──────────────────────────────────────────────────
function distPointToBezier(px,py,sx,sy,cp1x,cp1y,cp2x,cp2y,tx,ty){
  // Sample 20 points along bezier, return min distance
  let minD=Infinity;
  for(let i=0;i<=20;i++){
    const t=i/20,u=1-t;
    const x=u*u*u*sx+3*u*u*t*cp1x+3*u*t*t*cp2x+t*t*t*tx;
    const y=u*u*u*sy+3*u*u*t*cp1y+3*u*t*t*cp2y+t*t*t*ty;
    minD=Math.min(minD,Math.hypot(px-x,py-y));
  }
  return minD;
}

function connAt(wx,wy){
  const threshold=10/scale;
  for(let i=conns.length-1;i>=0;i--){
    const conn=conns[i];
    const s=gn(conn.s),t=gn(conn.t);
    if(!s||!t||isHidden(conn.s)||isHidden(conn.t))continue;
    const sp=nodeBorderPt(s,t.x,t.y);
    const tp=nodeBorderPt(t,s.x,s.y);
    const dx=tp.x-sp.x;
    const cp1x=sp.x+dx*.45,cp1y=sp.y;
    const cp2x=tp.x-dx*.45,cp2y=tp.y;
    const d=distPointToBezier(wx,wy,sp.x,sp.y,cp1x,cp1y,cp2x,cp2y,tp.x,tp.y);
    if(d<threshold)return conn;
  }
  return null;
}

function connMidpoint(conn){
  const s=gn(conn.s),t=gn(conn.t);
  if(!s||!t)return{x:0,y:0};
  const sp=nodeBorderPt(s,t.x,t.y);
  const tp=nodeBorderPt(t,s.x,s.y);
  const dx=tp.x-sp.x;
  // Bezier midpoint at t=0.5
  const u=0.5;
  return{
    x:u*u*u*sp.x+3*u*u*u*(sp.x+dx*.45)+3*u*u*u*(tp.x-dx*.45)+u*u*u*tp.x,
    y:0.125*sp.y+3*0.125*sp.y+3*0.125*tp.y+0.125*tp.y
  };
}

function connMidPt(conn){
  // Correct midpoint (t=0.5)
  const s=gn(conn.s),t=gn(conn.t);
  if(!s||!t)return{x:0,y:0};
  const sp=nodeBorderPt(s,t.x,t.y);
  const tp=nodeBorderPt(t,s.x,s.y);
  const dx=tp.x-sp.x;
  const cp1x=sp.x+dx*.45,cp1y=sp.y,cp2x=tp.x-dx*.45,cp2y=tp.y;
  const tt=0.5,u=0.5;
  return{
    x:u*u*u*sp.x+3*u*u*tt*cp1x+3*u*tt*tt*cp2x+tt*tt*tt*tp.x,
    y:u*u*u*sp.y+3*u*u*tt*cp1y+3*u*tt*tt*cp2y+tt*tt*tt*tp.y
  };
}

function nodeAt(wx,wy){for(let i=nodes.length-1;i>=0;i--){const n=nodes[i];if(isHidden(n.id))continue;if(wx>=n.x-n.width/2&&wx<=n.x+n.width/2&&wy>=n.y-n.height/2&&wy<=n.y+n.height/2)return n;}return null;}

cv.addEventListener('mousemove',e=>{
  const now=Date.now();const wx=cli2w(e.clientX,e.clientY).x,wy=cli2w(e.clientX,e.clientY).y;
  // Shape drag
  if(dragShapeId){const s=shapes.find(x=>x.id===dragShapeId);if(s){s.x=wx-dragShapeOX;s.y=wy-dragShapeOY;}render();return;}
  // Shape resize
  if(resizingShape&&resizeHandle){
    const s=shapes.find(x=>x.id===resizingShape);
    if(s){
      const hw=s.width/2,hh=s.height/2;
      if(resizeHandle.includes('r')){s.width=Math.max(40,(wx-s.x+hw)*2);} // simplify: adjust width/height
      if(resizeHandle.includes('l')){const newW=Math.max(40,(s.x+hw-wx)*2);s.width=newW;}
      if(resizeHandle.includes('b')){s.height=Math.max(30,(wy-s.y+hh)*2);}
      if(resizeHandle.includes('t')){const newH=Math.max(30,(s.y+hh-wy)*2);s.height=newH;}
    }
    render();return;
  }
  // Frame drag
  if(dragFrameId){
    const f=frames.find(x=>x.id===dragFrameId);
    if(f){
      const dx=wx-dragShapeOX-f.x,dy=wy-dragShapeOY-f.y;
      // Move frame
      f.x+=dx;f.y+=dy;
      // Move contained nodes and shapes
      nodesInFrame({x:f.x-dx,y:f.y-dy,width:f.width,height:f.height}).forEach(n=>{n.x+=dx;n.y+=dy;});
      shapesInFrame({x:f.x-dx,y:f.y-dy,width:f.width,height:f.height}).forEach(s=>{s.x+=dx;s.y+=dy;});
      dragShapeOX=wx-f.x;dragShapeOY=wy-f.y;
    }
    render();mmR();return;
  }
  // Frame resize
  if(selFrameId&&resizeHandle){
    const f=frames.find(x=>x.id===selFrameId);
    if(f){
      if(resizeHandle==='br'){f.width=Math.max(60,wx-f.x);f.height=Math.max(40,wy-f.y);}
      else if(resizeHandle==='bl'){const nw=Math.max(60,f.x+f.width-wx);f.x=f.x+f.width-nw;f.width=nw;f.height=Math.max(40,wy-f.y);}
      else if(resizeHandle==='tr'){f.width=Math.max(60,wx-f.x);const nh=Math.max(40,f.y+f.height-wy);f.y=f.y+f.height-nh;f.height=nh;}
      else if(resizeHandle==='tl'){const nw=Math.max(60,f.x+f.width-wx);f.x=f.x+f.width-nw;f.width=nw;const nh=Math.max(40,f.y+f.height-wy);f.y=f.y+f.height-nh;f.height=nh;}
    }
    render();return;
  }
  // Creating frame
  if(creatingFrame){frameStart.ex=wx;frameStart.ey=wy;render();return;}
  if(dragId){
    const n=gn(dragId);if(n){const dx=wx-dragOX-n.x,dy=wy-dragOY-n.y;n.x+=dx;n.y+=dy;multiDragOffsets.forEach((off,sid)=>{if(sid!==dragId){const sn=gn(sid);if(sn){sn.x+=dx;sn.y+=dy;}}});}
    dragOX=wx-gn(dragId).x;dragOY=wy-gn(dragId).y;
    // Reparent detection
    const dragDist=Math.hypot(wx-dragStartX,wy-dragStartY);
    if(dragDist>40){const candidate=nodeAt(wx,wy);if(candidate&&candidate.id!==dragId&&!isDescendantOf(candidate.id,dragId)){reparentTarget=candidate;}else{reparentTarget=null;}}
    posFtb();render();mmR();return;
  }
  if(panning){const r=cwEl().getBoundingClientRect();viewX=e.clientX-r.left-panSX;viewY=e.clientY-HH-panSY;render();mmR();return;}
  if(connFrom){connMouse={x:wx,y:wy};render();return;}
  if(selRectStart){selRect={sx:selRectStart.x,sy:selRectStart.y,ex:wx,ey:wy};render();return;}
  if(now-lastHov>25){lastHov=now;const n=nodeAt(wx,wy);const nid=n?n.id:null;if(nid!==hovId){hovId=nid;render();}if(n){if(onCollBtn(n,wx,wy))cv.style.cursor='pointer';else if(onEdge(n,wx,wy))cv.style.cursor='crosshair';else cv.style.cursor='grab';}else cv.style.cursor=(activeTool==='pan'||spaceDown)?'grab':'default';}
});

cv.addEventListener('mousedown',e=>{
  e.preventDefault();hideCM();urlpop.classList.remove('v');
  const wx=cli2w(e.clientX,e.clientY).x,wy=cli2w(e.clientX,e.clientY).y;const n=nodeAt(wx,wy);
  // ── Connection delete button click ─────────────────────────────────
  if(selConnId&&e.button===0){
    const sc2=conns.find(x=>x.id===selConnId);
