<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MindMap Studio</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

:root {
  --bg:#f2f4f8;--canvas:#edf0f6;--surf:#fff;--surf2:#f7f8fc;--surf3:#eef0f7;
  --brd:#e2e6f0;--brd2:#c8cee0;--txt:#1a1d2e;--txt2:#5a5f7d;--txt3:#9aa0bf;
  --acc:#5b6af0;--acc2:#818cf8;--acc3:#3d4edc;
  --ok:#2cb67d;--er:#f06464;--warn:#f0a500;--info:#0ea5e9;
  --hh:50px;--sbw:46px;--rw:280px;
  --shadow:0 1px 8px rgba(0,0,0,.07);--shadow2:0 6px 28px rgba(0,0,0,.11);--r:10px;
}
body.dark{--bg:#0f1117;--canvas:#0c0e14;--surf:#171923;--surf2:#1e2130;--surf3:#252839;--brd:#2a2f45;--brd2:#363c58;--txt:#e4e8f8;--txt2:#8890b8;--txt3:#4a5070;--shadow:0 1px 8px rgba(0,0,0,.25);--shadow2:0 6px 28px rgba(0,0,0,.45);}





*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--txt);overflow:hidden;height:100vh;width:100vw;user-select:none;transition:background .25s,color .25s;}

/* ── HEADER ── */
#hdr{position:fixed;top:0;left:0;right:0;height:var(--hh);background:var(--surf);border-bottom:1px solid var(--brd);display:flex;align-items:center;padding:0 12px;gap:7px;z-index:300;box-shadow:var(--shadow);}
#logo{font-size:15px;font-weight:700;color:var(--acc);letter-spacing:-.3px;flex-shrink:0;white-space:nowrap;}
#logo span{font-weight:300;color:var(--txt3);font-size:12px;}
.hsep{width:1px;height:20px;background:var(--brd);flex-shrink:0;}
#sw{display:flex;align-items:center;background:var(--surf2);border:1.5px solid var(--brd);border-radius:20px;padding:0 11px;gap:6px;height:30px;min-width:160px;transition:border-color .15s,box-shadow .15s;}
#sw:focus-within{border-color:var(--acc);box-shadow:0 0 0 3px rgba(91,106,240,.1);}
#si{background:transparent;border:none;outline:none;font:13px 'Inter',sans-serif;color:var(--txt);width:100%;}
#si::placeholder{color:var(--txt3);}
#sc{background:none;border:none;cursor:pointer;color:var(--txt3);font-size:13px;display:none;}
#sc.v{display:block;}
#sk{font-size:10px;color:var(--txt3);display:none;white-space:nowrap;}
#sk.v{display:block;}
.hbtn{height:30px;padding:0 10px;background:transparent;border:1.5px solid var(--brd);color:var(--txt2);font:500 12px 'Inter',sans-serif;border-radius:8px;cursor:pointer;transition:all .14s;white-space:nowrap;flex-shrink:0;display:flex;align-items:center;gap:5px;}
.hbtn:hover{border-color:var(--acc);color:var(--acc);background:rgba(91,106,240,.06);}
.hbtn.pri{background:var(--acc);border-color:transparent;color:#fff;font-weight:600;}
.hbtn.pri:hover{background:var(--acc2);}

.hsp{flex:1;}
#dtog{width:30px;height:30px;background:var(--surf2);border:1.5px solid var(--brd);border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;transition:all .14s;}
#dtog:hover{border-color:var(--acc);}

/* ── LEFT SIDEBAR ── */
#lsb{position:fixed;top:var(--hh);left:0;bottom:0;width:var(--sbw);background:var(--surf);border-right:1px solid var(--brd);display:flex;flex-direction:column;align-items:center;padding:8px 0;gap:2px;z-index:200;}
.stool{width:32px;height:32px;background:transparent;border:none;border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--txt3);transition:all .12s;font-size:14px;position:relative;}
.stool:hover{background:var(--surf2);color:var(--txt);}
.stool.on{background:rgba(91,106,240,.12);color:var(--acc);}
.stool[title]:hover::after{content:attr(title);position:absolute;left:calc(100%+8px);top:50%;transform:translateY(-50%);background:var(--txt);color:var(--bg);font-size:10px;font-weight:500;padding:3px 8px;border-radius:5px;white-space:nowrap;pointer-events:none;z-index:999;}
.lsep{width:28px;height:1px;background:var(--brd);margin:3px 0;flex-shrink:0;}

/* ── CANVAS ── */
#cw{position:fixed;top:var(--hh);left:var(--sbw);right:0;bottom:0;}
#mc{display:block;}
#lb{position:fixed;top:var(--hh);left:var(--sbw);right:0;height:3px;background:linear-gradient(90deg,var(--acc),var(--ok),var(--warn));transform:scaleX(0);transform-origin:left;z-index:250;display:none;border-radius:0 2px 2px 0;}

/* ── RIGHT PANEL ── */
#rp{position:fixed;top:var(--hh);right:calc(-1 * var(--rw) - 4px);width:var(--rw);bottom:0;background:var(--surf);border-left:1px solid var(--brd);z-index:200;transition:right .28s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;box-shadow:var(--shadow2);}
#rp.open{right:0;}
#rph{padding:12px 14px 10px;border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:8px;}
#rp-icon{font-size:16px;flex-shrink:0;}
#rp-title{flex:1;font-size:13px;font-weight:600;color:var(--txt);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
#rp-close{width:24px;height:24px;background:var(--surf2);border:1.5px solid var(--brd);border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--txt3);font-size:12px;}
#rp-close:hover{border-color:var(--er);color:var(--er);}
#rpb{flex:1;overflow-y:auto;padding:12px 14px;}
#rpb::-webkit-scrollbar{width:3px;}
#rpb::-webkit-scrollbar-thumb{background:var(--brd);border-radius:2px;}
.rps{margin-bottom:16px;}
.rpl{font-size:10px;font-weight:600;color:var(--txt3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:7px;}
.rpin{width:100%;background:var(--surf2);border:1.5px solid var(--brd);color:var(--txt);font:12px 'Inter',sans-serif;padding:8px 10px;border-radius:8px;outline:none;resize:none;line-height:1.7;}
.rpin:focus{border-color:var(--acc);}
.rprow{display:flex;align-items:flex-start;gap:6px;margin-bottom:6px;}
.rprow label{font-size:11px;color:var(--txt2);width:58px;flex-shrink:0;padding-top:9px;}
.color-row{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px;}
.color-swatch{width:22px;height:22px;border-radius:5px;cursor:pointer;border:2.5px solid transparent;transition:all .12s;}
.color-swatch:hover,.color-swatch.on{border-color:var(--txt);transform:scale(1.1);}
.color-custom input[type=color]{width:22px;height:22px;padding:1px;cursor:pointer;border-radius:5px;border:1.5px solid var(--brd);}
.conn-style-row{display:flex;gap:4px;flex-wrap:wrap;}
.conn-style-btn{padding:4px 8px;background:var(--surf2);border:1.5px solid var(--brd);color:var(--txt2);font:500 10px 'Inter',sans-serif;border-radius:6px;cursor:pointer;transition:all .12s;}
.conn-style-btn:hover{border-color:var(--acc);color:var(--acc);}
.conn-style-btn.on{background:var(--acc);border-color:transparent;color:#fff;}
.tagedit{display:inline-flex;align-items:center;gap:3px;padding:3px 8px;border-radius:20px;font-size:11px;font-weight:600;cursor:pointer;border:1.5px solid;}
.tagedit .td{cursor:pointer;opacity:.5;font-size:10px;}
.tagedit .td:hover{opacity:1;}
#add-tag-btn{height:24px;padding:0 10px;background:var(--surf3);border:1.5px dashed var(--brd2);color:var(--txt3);font:500 11px 'Inter',sans-serif;border-radius:20px;cursor:pointer;transition:all .12px;}
#add-tag-btn:hover{border-color:var(--acc);color:var(--acc);}
.shape-opt{flex:1;padding:4px 0;background:var(--surf2);border:1.5px solid var(--brd);border-radius:6px;cursor:pointer;text-align:center;font-size:11px;font-weight:500;color:var(--txt2);transition:all .12s;}
.shape-opt:hover{border-color:var(--acc);color:var(--acc);}
.shape-opt.on{background:rgba(91,106,240,.1);border-color:var(--acc);color:var(--acc);}

/* ── TAG FILTER ── */
#tag-filter-bar{display:none;align-items:center;gap:5px;padding:5px 10px;background:var(--surf2);border-bottom:1px solid var(--brd);position:fixed;top:var(--hh);left:var(--sbw);right:0;z-index:150;flex-wrap:wrap;}
#tag-filter-bar.v{display:flex;}
.tfchip{height:24px;padding:0 10px;border-radius:12px;border:1.5px solid var(--brd);background:var(--surf);color:var(--txt2);font:500 11px 'Inter',sans-serif;cursor:pointer;transition:all .12s;}
.tfchip:hover,.tfchip.on{border-color:var(--acc);color:var(--acc);background:rgba(91,106,240,.08);}
#tag-filter-close{margin-left:auto;background:none;border:none;color:var(--txt3);cursor:pointer;font-size:13px;}
body.tfilter #cw{top:calc(var(--hh)+34px);}
body.tfilter #lb{top:calc(var(--hh)+34px);}
body.tfilter #rp{top:calc(var(--hh)+34px);}
body.tfilter #lsb{top:calc(var(--hh)+34px);}

/* ── FLOATING TOOLBAR ── */
#ftb{position:fixed;background:var(--surf);border:1.5px solid var(--brd);border-radius:10px;padding:3px 5px;display:none;align-items:center;gap:1px;z-index:280;box-shadow:var(--shadow2);}
#ftb.v{display:flex;}
/* Shape floating toolbar */
#sftb{position:fixed;background:var(--surf);border:1.5px solid var(--brd);border-radius:10px;padding:3px 5px;display:none;align-items:center;gap:1px;z-index:280;box-shadow:var(--shadow2);}
#sftb.v{display:flex;}
#fftb{position:fixed;background:var(--surf);border:1.5px solid var(--brd);border-radius:10px;padding:3px 5px;display:none;align-items:center;gap:1px;z-index:280;box-shadow:var(--shadow2);}
#fftb.v{display:flex;}
.fb{width:28px;height:28px;background:transparent;border:none;border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--txt2);font-size:13px;font-weight:700;transition:all .12s;position:relative;}
.fb:hover{background:var(--surf2);color:var(--txt);}
.fb[title]:hover::after{content:attr(title);position:absolute;bottom:-26px;left:50%;transform:translateX(-50%);background:var(--txt);color:var(--bg);font-size:10px;padding:2px 7px;border-radius:4px;white-space:nowrap;pointer-events:none;font-weight:500;z-index:999;}
.fb.danger:hover{background:rgba(240,100,100,.1);color:var(--er);}
.fbsep{width:1px;height:16px;background:var(--brd);}

/* ── CONTEXT MENU ── */
#cm{position:fixed;background:var(--surf);border:1.5px solid var(--brd);border-radius:10px;padding:5px;z-index:500;display:none;min-width:185px;box-shadow:var(--shadow2);}
.cmi{display:flex;align-items:center;gap:9px;padding:7px 11px;border-radius:7px;cursor:pointer;font-size:12px;font-weight:500;color:var(--txt);transition:background .1s;}
.cmi:hover{background:rgba(91,106,240,.08);color:var(--acc);}
.cmi svg{width:13px;height:13px;flex-shrink:0;opacity:.6;}
.cmi.danger:hover{background:rgba(240,100,100,.08);color:var(--er);}
.cmi kbd{margin-left:auto;font-size:10px;color:var(--txt3);background:var(--surf2);border-radius:4px;padding:1px 6px;}
.cmsep{height:1px;background:var(--brd);margin:3px 0;}

/* ── MINIMAP ── */
#mm{position:fixed;bottom:14px;right:14px;width:165px;height:105px;background:var(--surf);border:1.5px solid var(--brd);border-radius:10px;overflow:hidden;z-index:150;box-shadow:var(--shadow);}
#mmc{display:block;}
#mmvp{position:absolute;border:1.5px solid var(--acc);border-radius:2px;background:rgba(91,106,240,.07);pointer-events:none;}

/* ── INLINE EDIT ── */
#ni{position:fixed;background:var(--surf);border:2px solid var(--acc);border-radius:8px;color:var(--txt);font:500 13px 'Inter',sans-serif;padding:5px 11px;z-index:600;display:none;min-width:100px;outline:none;box-shadow:0 0 0 4px rgba(91,106,240,.12);}

/* ── URL POPOVER ── */
#urlpop{position:fixed;background:var(--surf);border:1.5px solid var(--brd);border-radius:10px;padding:10px 12px;z-index:400;display:none;gap:7px;box-shadow:var(--shadow2);min-width:260px;}
#urlpop.v{display:flex;}
#urlinput{flex:1;background:var(--surf2);border:1.5px solid var(--brd);color:var(--txt);font:12px 'Inter',sans-serif;padding:6px 9px;border-radius:7px;outline:none;}
#urlinput:focus{border-color:var(--acc);}
#urlok{padding:0 12px;height:30px;background:var(--acc);border:none;color:#fff;font:600 12px 'Inter',sans-serif;border-radius:7px;cursor:pointer;}
#urlclear{padding:0 10px;height:30px;background:var(--surf3);border:1.5px solid var(--brd);color:var(--txt2);font:500 12px 'Inter',sans-serif;border-radius:7px;cursor:pointer;}

/* ── TOAST ── */
#tw{position:fixed;bottom:18px;left:50%;transform:translateX(-50%);z-index:700;display:flex;flex-direction:column;align-items:center;gap:6px;pointer-events:none;}
.tst{background:var(--surf);border:1.5px solid var(--brd);border-radius:8px;padding:8px 18px;font-size:12px;font-weight:500;color:var(--txt);box-shadow:var(--shadow2);animation:tin .2s ease;pointer-events:auto;white-space:nowrap;}
.tst.ok{border-color:var(--ok);color:var(--ok);}
.tst.er{border-color:var(--er);color:var(--er);}
.tst.in{border-color:var(--acc);color:var(--acc);}
@keyframes tin{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

/* ═══════════════════════════════════════════════════
   TEMPLATE GALLERY MODAL
═══════════════════════════════════════════════════ */
#tpl-overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);backdrop-filter:blur(6px);z-index:800;display:none;align-items:center;justify-content:center;}
#tpl-overlay.open{display:flex;}
#tpl-modal{
  background:var(--surf);border:1.5px solid var(--brd);border-radius:18px;
  width:min(940px,96vw);max-height:86vh;display:flex;flex-direction:column;
  box-shadow:0 24px 80px rgba(0,0,0,.25);overflow:hidden;
}
#tpl-header{padding:20px 24px 16px;border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:14px;}
#tpl-title{font-size:18px;font-weight:700;color:var(--txt);}
#tpl-subtitle{font-size:12px;color:var(--txt3);margin-top:2px;}
#tpl-close{margin-left:auto;width:32px;height:32px;background:var(--surf2);border:1.5px solid var(--brd);border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--txt2);font-size:16px;transition:all .12s;}
#tpl-close:hover{border-color:var(--er);color:var(--er);}

/* User template actions */
.tpl-card-user{position:relative;}
.tpl-card-user .tpl-del{
  position:absolute;top:6px;right:6px;
  width:22px;height:22px;background:var(--surf);border:1.5px solid var(--brd);
  border-radius:6px;cursor:pointer;display:none;align-items:center;
  justify-content:center;font-size:11px;color:var(--er);transition:all .12s;z-index:2;
}
.tpl-card-user:hover .tpl-del{display:flex;}
.tpl-card-user .tpl-del:hover{background:var(--er);color:#fff;border-color:var(--er);}
.tpl-header-actions{display:flex;align-items:center;gap:7px;}

/* Category tabs */
#tpl-cats{display:flex;gap:6px;padding:14px 24px 0;flex-wrap:wrap;border-bottom:1px solid var(--brd);padding-bottom:14px;}
.tpl-cat{height:28px;padding:0 14px;background:var(--surf2);border:1.5px solid var(--brd);color:var(--txt2);font:500 12px 'Inter',sans-serif;border-radius:20px;cursor:pointer;transition:all .12s;white-space:nowrap;}
.tpl-cat:hover{border-color:var(--acc);color:var(--acc);}
.tpl-cat.on{background:var(--acc);border-color:transparent;color:#fff;}

/* Grid */
#tpl-grid{flex:1;overflow-y:auto;padding:20px 24px;display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;}
#tpl-grid::-webkit-scrollbar{width:4px;}
#tpl-grid::-webkit-scrollbar-thumb{background:var(--brd);border-radius:2px;}

.tpl-card{
  background:var(--surf2);border:1.5px solid var(--brd);border-radius:12px;
  cursor:pointer;transition:all .18s;overflow:hidden;
  display:flex;flex-direction:column;
}
.tpl-card:hover{border-color:var(--acc);transform:translateY(-2px);box-shadow:0 8px 24px rgba(91,106,240,.15);}
.tpl-card:active{transform:translateY(0);}
.tpl-preview{height:110px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;border-bottom:1px solid var(--brd);}
.tpl-preview svg{width:100%;height:100%;}
.tpl-info{padding:10px 12px;}
.tpl-name{font-size:12px;font-weight:600;color:var(--txt);margin-bottom:2px;}
.tpl-desc{font-size:10px;color:var(--txt3);line-height:1.5;}
.tpl-badge{display:inline-block;padding:2px 7px;border-radius:10px;font-size:9px;font-weight:600;margin-top:5px;}

/* Empty card (blank) */
.tpl-card.blank .tpl-preview{background:linear-gradient(135deg,var(--surf3),var(--surf2));}
.tpl-blank-icon{font-size:32px;opacity:.4;}

/* ── HELP ── */
/* ── MAPS MANAGER ── */
#maps-overlay{position:fixed;inset:0;background:rgba(0,0,0,.52);backdrop-filter:blur(5px);z-index:800;display:none;align-items:center;justify-content:center;}
#maps-overlay.open{display:flex;}
#maps-modal{background:var(--surf);border:1.5px solid var(--brd);border-radius:18px;width:min(780px,96vw);max-height:84vh;display:flex;flex-direction:column;box-shadow:0 24px 80px rgba(0,0,0,.25);overflow:hidden;}
#maps-hdr{padding:18px 22px 14px;border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:12px;}
#maps-hdr-title{font-size:16px;font-weight:700;color:var(--txt);flex:1;}
#maps-hdr-sub{font-size:11px;color:var(--txt3);margin-top:2px;}
#maps-close-btn{width:30px;height:30px;background:var(--surf2);border:1.5px solid var(--brd);border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--txt2);font-size:14px;}
#maps-close-btn:hover{border-color:var(--er);color:var(--er);}
#maps-toolbar{padding:10px 22px;border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:8px;}

#maps-search:focus{border-color:var(--acc);}
#maps-grid{flex:1;overflow-y:auto;padding:16px 22px;display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;}
#maps-grid::-webkit-scrollbar{width:4px;}
#maps-grid::-webkit-scrollbar-thumb{background:var(--brd);border-radius:2px;}
.map-card{background:var(--surf2);border:1.5px solid var(--brd);border-radius:12px;overflow:hidden;cursor:pointer;transition:all .16s;display:flex;flex-direction:column;}
.map-card:hover{border-color:var(--acc);transform:translateY(-2px);box-shadow:0 6px 20px rgba(91,106,240,.15);}
.map-card.active{border-color:var(--acc);background:rgba(91,106,240,.06);}
.map-thumb{height:100px;display:flex;align-items:center;justify-content:center;border-bottom:1px solid var(--brd);overflow:hidden;background:var(--surf3);}
.map-thumb svg{width:100%;height:100%;}
.map-info{padding:9px 11px;}
.map-name{font-size:12px;font-weight:600;color:var(--txt);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.map-meta{font-size:10px;color:var(--txt3);}
.map-actions{display:flex;gap:4px;padding:0 8px 8px;margin-top:2px;}
.map-act{flex:1;height:24px;background:var(--surf);border:1.5px solid var(--brd);color:var(--txt2);font:500 10px 'Inter',sans-serif;border-radius:6px;cursor:pointer;transition:all .12s;}
.map-act:hover{border-color:var(--acc);color:var(--acc);}
.map-act.danger:hover{border-color:var(--er);color:var(--er);}
.map-card-new{background:transparent;border:1.5px dashed var(--brd2);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;min-height:160px;cursor:pointer;border-radius:12px;transition:all .16s;color:var(--txt3);}
.map-card-new:hover{border-color:var(--acc);color:var(--acc);background:rgba(91,106,240,.04);}
.map-card-new-icon{font-size:28px;opacity:.5;}
.map-card-new-label{font-size:12px;font-weight:600;}
.map-badge-active{display:inline-block;background:var(--acc);color:#fff;font-size:9px;font-weight:700;padding:1px 6px;border-radius:10px;margin-left:5px;vertical-align:middle;}

/* ── PALETTE POPUP ── */
#pal-popup{
  position:fixed;background:var(--surf);border:1.5px solid var(--brd);
  border-radius:14px;padding:14px;z-index:400;display:none;
  box-shadow:var(--shadow2);width:340px;
}
#pal-popup.open{display:block;}
#pal-popup-inner{font-size:11px;font-weight:600;color:var(--txt3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;}
.pal-group{margin-bottom:12px;}
.pal-group-label{font-size:10px;font-weight:600;color:var(--txt3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px;}
.pal-row{display:flex;gap:6px;flex-wrap:wrap;}
.pal-card{display:flex;flex-direction:column;gap:3px;cursor:pointer;padding:7px 8px;border-radius:9px;border:1.5px solid transparent;transition:all .14s;background:var(--surf2);}
.pal-card:hover{border-color:var(--acc);transform:translateY(-1px);}
.pal-card.on{border-color:var(--acc);background:rgba(91,106,240,.08);}
.pal-swatches{display:flex;gap:3px;}
.pal-dot{width:12px;height:12px;border-radius:3px;flex-shrink:0;}
.pal-label{font-size:9px;font-weight:600;color:var(--txt2);white-space:nowrap;text-align:center;max-width:62px;overflow:hidden;text-overflow:ellipsis;}

/* ── EMOJI PICKER ── */
#emoji-picker-popup{
  position:fixed;background:var(--surf);border:1.5px solid var(--brd);
  border-radius:12px;padding:10px;z-index:450;display:none;
  box-shadow:var(--shadow2);width:224px;
}
#emoji-picker-popup.open{display:block;}
.ep-search{width:100%;background:var(--surf2);border:1.5px solid var(--brd);color:var(--txt);font:12px 'Inter',sans-serif;padding:5px 9px;border-radius:8px;outline:none;margin-bottom:8px;}
.ep-search:focus{border-color:var(--acc);}
.ep-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;max-height:180px;overflow-y:auto;}
.ep-grid::-webkit-scrollbar{width:3px;}
.ep-grid::-webkit-scrollbar-thumb{background:var(--brd);border-radius:2px;}
.ep-btn{width:28px;height:28px;display:flex;align-items:center;justify-content:center;font-size:17px;cursor:pointer;border-radius:6px;transition:background .1s;border:none;background:transparent;}
.ep-btn:hover{background:var(--surf2);}
.ep-none{padding:5px 8px;font-size:11px;color:var(--txt3);cursor:pointer;border-radius:6px;border:1.5px dashed var(--brd);text-align:center;margin-top:4px;}
.ep-none:hover{border-color:var(--er);color:var(--er);}

#help{position:fixed;bottom:7px;left:calc(var(--sbw)+9px);font-size:10px;color:var(--txt3);line-height:2;pointer-events:none;}
#imf{display:none;}

/* ══ MAPS DRAWER ══════════════════════════════════════════════════════════ */

#maps-drawer.open{transform:translateX(0);}

body.maps-open #lb{left:calc(var(--sbw) + 300px);}


.maps-hbtn{
  width:26px;height:26px;background:var(--surf2);border:1.5px solid var(--brd);
  border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;
  color:var(--txt2);font-size:12px;transition:all .12s;
}
.maps-hbtn:hover{border-color:var(--acc);color:var(--acc);}
.maps-hbtn.danger:hover{border-color:var(--er);color:var(--er);}




#maps-list::-webkit-scrollbar{width:3px;}
#maps-list::-webkit-scrollbar-thumb{background:var(--brd);border-radius:2px;}



.map-thumb{
  width:44px;height:32px;background:var(--surf3);border-radius:6px;
  flex-shrink:0;overflow:hidden;border:1px solid var(--brd);
}
.map-thumb canvas{display:block;}
.map-info{flex:1;min-width:0;}
.map-name{font-size:12px;font-weight:600;color:var(--txt);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.map-name-input{
  font-size:12px;font-weight:600;color:var(--txt);background:transparent;
  border:none;outline:none;border-bottom:1.5px solid var(--acc);
  width:100%;font-family:'Inter',sans-serif;
}
.map-meta{font-size:10px;color:var(--txt3);margin-top:1px;}
.map-actions{display:flex;gap:3px;flex-shrink:0;opacity:0;transition:opacity .12s;}
.map-item:hover .map-actions{opacity:1;}
.map-item.active .map-actions{opacity:1;}
.map-act{
  width:22px;height:22px;background:transparent;border:none;
  border-radius:5px;cursor:pointer;display:flex;align-items:center;
  justify-content:center;color:var(--txt3);font-size:11px;transition:all .1s;
}
.map-act:hover{background:var(--surf3);color:var(--txt);}
.map-act.danger:hover{background:rgba(240,100,100,.12);color:var(--er);}
#maps-footer{
  padding:10px 14px;border-top:1px solid var(--brd);flex-shrink:0;
  display:flex;gap:6px;
}
.maps-footer-btn{
  flex:1;height:32px;background:var(--surf2);border:1.5px solid var(--brd);
  color:var(--txt2);font:500 12px 'Inter',sans-serif;border-radius:8px;
  cursor:pointer;transition:all .14s;display:flex;align-items:center;justify-content:center;gap:5px;
}
.maps-footer-btn:hover{border-color:var(--acc);color:var(--acc);background:rgba(91,106,240,.06);}
.maps-footer-btn.pri{background:var(--acc);border-color:transparent;color:#fff;font-weight:600;}
.maps-footer-btn.pri:hover{background:var(--acc2);}
#maps-empty{
  padding:40px 20px;text-align:center;color:var(--txt3);font-size:12px;line-height:1.8;
}
#maps-empty .empty-icon{font-size:36px;margin-bottom:10px;}

/* ════ MAPS MANAGER ════ */
#maps-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);backdrop-filter:blur(5px);z-index:800;display:none;align-items:center;justify-content:center;}
#maps-overlay.open{display:flex;}
#maps-modal{background:var(--surf);border:1.5px solid var(--brd);border-radius:18px;width:min(900px,95vw);max-height:88vh;display:flex;flex-direction:column;box-shadow:0 24px 80px rgba(0,0,0,.25);overflow:hidden;}
#maps-modal-hdr{padding:18px 22px 14px;border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
#maps-modal-titles{flex:1;}
#maps-modal-title{font-size:17px;font-weight:700;color:var(--txt);}
#maps-modal-sub{font-size:11px;color:var(--txt3);margin-top:2px;}
#maps-modal-actions{display:flex;align-items:center;gap:7px;flex-wrap:wrap;}
#maps-search-input{background:var(--surf2);border:1.5px solid var(--brd);color:var(--txt);font:12px 'Inter',sans-serif;padding:5px 11px;border-radius:20px;outline:none;width:170px;height:30px;}
#maps-search-input:focus{border-color:var(--acc);}
#maps-close-btn{width:30px;height:30px;background:var(--surf2);border:1.5px solid var(--brd);border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--txt2);font-size:14px;transition:all .12s;flex-shrink:0;}
#maps-close-btn:hover{border-color:var(--er);color:var(--er);}
#maps-grid{flex:1;overflow-y:auto;padding:20px 22px;display:grid;grid-template-columns:repeat(auto-fill,minmax(195px,1fr));gap:14px;}
#maps-grid::-webkit-scrollbar{width:4px;}
#maps-grid::-webkit-scrollbar-thumb{background:var(--brd);border-radius:2px;}

/* Map cards */
.map-card{background:var(--surf2);border:1.5px solid var(--brd);border-radius:12px;cursor:pointer;transition:all .16s;overflow:hidden;display:flex;flex-direction:column;}
.map-card:hover{border-color:var(--acc);transform:translateY(-2px);box-shadow:0 8px 24px rgba(91,106,240,.14);}
.map-card.active{border-color:var(--acc);box-shadow:0 0 0 3px rgba(91,106,240,.15);}
.map-thumb{height:108px;background:var(--surf3);display:flex;align-items:center;justify-content:center;border-bottom:1px solid var(--brd);overflow:hidden;position:relative;}
.map-thumb svg{width:100%;height:100%;}
.map-thumb-badge{position:absolute;top:6px;right:6px;background:var(--acc);color:#fff;font-size:9px;font-weight:700;padding:2px 7px;border-radius:10px;}
.map-info{padding:10px 12px 6px;}
.map-name{font-size:12px;font-weight:600;color:var(--txt);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.map-meta{font-size:10px;color:var(--txt3);margin-top:2px;}
.map-actions{padding:6px 8px 9px;display:flex;gap:5px;}
.map-act{height:26px;padding:0 9px;background:var(--surf);border:1.5px solid var(--brd);color:var(--txt2);font:500 11px 'Inter',sans-serif;border-radius:7px;cursor:pointer;transition:all .12s;white-space:nowrap;}
.map-act:hover{border-color:var(--acc);color:var(--acc);}
.map-act.danger:hover{border-color:var(--er);color:var(--er);}
.map-act.open-btn{background:var(--acc);border-color:transparent;color:#fff;}
.map-act.open-btn:hover{background:var(--acc2);}

/* New map card */
.map-card-new{background:var(--surf2);border:2px dashed var(--brd2);border-radius:12px;cursor:pointer;transition:all .16s;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;min-height:180px;padding:20px;}
.map-card-new:hover{border-color:var(--acc);background:rgba(91,106,240,.05);}
.map-card-new-icon{font-size:28px;color:var(--txt3);transition:color .15s;}
.map-card-new:hover .map-card-new-icon{color:var(--acc);}
.map-card-new-label{font-size:12px;font-weight:600;color:var(--txt3);}
.map-card-new:hover .map-card-new-label{color:var(--acc);}

#layout-popup {
  position: fixed; background: var(--surf); border: 1.5px solid var(--brd);
  border-radius: 12px; padding: 10px; z-index: 500; display: none;
  box-shadow: var(--shadow2); width: 252px;
}
#layout-popup.open { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.lopt {
  padding: 10px 6px; background: var(--surf2); border: 1.5px solid var(--brd);
  border-radius: 9px; cursor: pointer; text-align: center; font-size: 11px;
  font-weight: 600; color: var(--txt2); transition: all .14s;
  display: flex; flex-direction: column; align-items: center; gap: 5px;
}
.lopt:hover { border-color: var(--acc); color: var(--acc); background: rgba(91,106,240,.06); }
.lopt svg { width: 40px; height: 32px; }
.lopt.partial{border-style:dashed;}
.lopt-sep{grid-column:1/-1;font-size:10px;font-weight:600;color:var(--txt3);text-transform:uppercase;letter-spacing:.5px;padding:6px 0 2px;border-top:1px solid var(--brd);margin-top:2px;}
#btn-focus.active{background:var(--acc);border-color:transparent;color:#fff;}
</style>
</head>
