    const lv=ch.map(c=>countLeaves(c.id));
    const tot=lv.reduce((a,b)=>a+b,0);
    let curY = yCenter - (tot-1)*yGap/2;
    ch.forEach((c,i)=>{ place(c.id, depth+1, curY+lv[i]*yGap/2); curY+=lv[i]*yGap; });
  }
  place(root.id, 0, rootY);
}


function rebuildParentIds() {
  // Rebuild only hierarchy metadata used by layout.
  // Colors must never be mutated here.

  // STEP 1 — Find the true root
  const roots = nodes.filter(n => n.depth === 0 && !n.parentId);
  if (!roots.length) return;

  function countReachable(startId) {
    const vis = new Set();
    const q = [startId];
    while (q.length) {
      const id = q.pop();
      if (vis.has(id)) continue;
      vis.add(id);
      conns.forEach(cc => {
        if (cc.s === id && !vis.has(cc.t)) q.push(cc.t);
        if (cc.t === id && !vis.has(cc.s)) q.push(cc.s);
      });
    }
    return vis.size;
  }

  const root = roots.reduce((best, r) =>
    countReachable(r.id) > countReachable(best.id) ? r : best, roots[0]);

  // STEP 3 — BFS from root using conns[], respecting s→t direction (parent→child)
  // Reset ALL nodes first — full rebuild guarantees correct hierarchy
  nodes.forEach(n => { n.parentId = null; n.depth = 0; });

  const visited = new Set();
  // Queue entries: {id, parentId, depth}
  // Primary pass: follow s→t (explicit parent→child direction from addConn)
  const primaryQueue = [{ id: root.id, parentId: null, depth: 0 }];

  while (primaryQueue.length) {
    const { id, parentId, depth } = primaryQueue.shift();
    if (visited.has(id)) continue;
    visited.add(id);
    const n = gn(id);
    if (!n) continue;
    n.parentId = parentId;
    n.depth = depth;
    // s→t children (canonical direction)
    conns
      .filter(cc => cc.s === id && !visited.has(cc.t))
      .forEach(cc => primaryQueue.push({ id: cc.t, parentId: id, depth: depth + 1 }));
  }

  // Secondary pass: pick up nodes unreached via s→t (drag-created connections t→s)
  const secondaryQueue = [];
  conns.forEach(cc => {
    if (visited.has(cc.s) && !visited.has(cc.t))
      secondaryQueue.push({ id: cc.t, parentId: cc.s, depth: (gn(cc.s)||{depth:0}).depth + 1 });
    if (visited.has(cc.t) && !visited.has(cc.s))
      secondaryQueue.push({ id: cc.s, parentId: cc.t, depth: (gn(cc.t)||{depth:0}).depth + 1 });
  });

  while (secondaryQueue.length) {
    const { id, parentId, depth } = secondaryQueue.shift();
    if (visited.has(id)) continue;
    visited.add(id);
    const n = gn(id);
    if (!n) continue;
    n.parentId = parentId;
    n.depth = depth;
    conns
      .filter(cc => (cc.s === id || cc.t === id) && !visited.has(cc.s === id ? cc.t : cc.s))
      .forEach(cc => secondaryQueue.push({
        id: cc.s === id ? cc.t : cc.s,
        parentId: id,
        depth: depth + 1
      }));
  }

  // STEP 4 — Update typography only, never colors
  nodes.forEach(n => {
    n.fontSize   = n.depth === 0 ? 17 : n.depth === 1 ? 14 : 13;
    n.fontWeight = n.depth === 0 ? 700 : n.depth === 1 ? 600 : 500;
  });
}

function attachOrphans() {
  rebuildParentIds();
  const roots = nodes.filter(n=>!n.parentId);
  if(roots.length <= 1) return;
  function countDesc(id){return kids(id).reduce((s,c)=>s+1+countDesc(c.id),0);}
  roots.sort((a,b)=>countDesc(b.id)-countDesc(a.id));
  const mainRoot = roots[0];
  roots.slice(1).forEach(orphan=>{
    // Remove ALL existing connections involving this orphan
    conns = conns.filter(cc=>cc.s!==orphan.id&&cc.t!==orphan.id);
    orphan.parentId = mainRoot.id;
    orphan.depth = 1;
    function reDepth(nid,d){const x=gn(nid);if(!x)return;x.depth=d;kids(nid).forEach(c=>reDepth(c.id,d+1));}
    reDepth(orphan.id, 1);
    addConn(mainRoot.id, orphan.id, 'h');
  });
}
function getMaxDepth(id,d=0){const ch=kids(id);return ch.length?Math.max(...ch.map(c=>getMaxDepth(c.id,d+1))):d;}
function layoutTreeV() {
  attachOrphans();
  const root = nodes.find(n=>!n.parentId); if(!root)return;
  function countLeaves(id){ const ch=kids(id); return ch.length?ch.reduce((s,c)=>s+countLeaves(c.id),0):1; }
  const yGap = 140, xGap = 190;
  const cx = (cv.width/2 - viewX) / scale;
  const cy = (cv.height/2 - viewY) / scale;
  const maxD = getMaxDepth(root.id);
  const rootX = cx;
  const rootY = cy - (maxD * yGap) / 2;
  root.x = rootX; root.y = rootY;
  function place(id, depth, xCenter) {
    const n=gn(id); if(!n)return;
    n.x = xCenter;
    n.y = rootY + depth * yGap;
    const ch=kids(id); if(!ch.length)return;
    const lv=ch.map(c=>countLeaves(c.id));
    const tot=lv.reduce((a,b)=>a+b,0);
    let curX = xCenter - (tot-1)*xGap/2;
    ch.forEach((c,i)=>{ place(c.id, depth+1, curX+lv[i]*xGap/2); curX+=lv[i]*xGap; });
  }
  place(root.id, 0, cx);
}
function layoutLR() {
  attachOrphans();
  const root = nodes.find(n=>!n.parentId); if(!root)return;
  const cx = (cv.width/2 - viewX) / scale;
  const cy = (cv.height/2 - viewY) / scale;
  root.x = cx; root.y = cy;
  const ch = kids(root.id);
  // Interleave: sort by leaf count descending, alternate right/left
  // This gives more balanced sides
  const sorted = [...ch].sort((a,b)=>{
    function cl(id){const c2=kids(id);return c2.length?c2.reduce((s,x)=>s+cl(x.id),0):1;}
    return cl(b.id)-cl(a.id);
  });
  const right=[], left=[];
  sorted.forEach((n,i)=>{ if(i%2===0) right.push(n); else left.push(n); });
  function countLeaves(id){ const ch2=kids(id); return ch2.length?ch2.reduce((s,c)=>s+countLeaves(c.id),0):1; }
  function placeBranch(id, px, py, dir) {
    const n=gn(id); if(!n)return;
    n.x=px; n.y=py;
    const ch2=kids(id); if(!ch2.length)return;
    const lv=ch2.map(c=>countLeaves(c.id));
    const tot=lv.reduce((a,b)=>a+b,0);
    const yGap=75, xStep=190;
    let curY=py-(tot-1)*yGap/2;
    ch2.forEach((c,i)=>{ placeBranch(c.id, px+dir*xStep, curY+lv[i]*yGap/2, dir); curY+=lv[i]*yGap; });
  }
  function placeSide(list, dir) {
    const lv=list.map(n=>countLeaves(n.id));
    const tot=lv.reduce((a,b)=>a+b,0);
    const yGap=75;
    let curY=cy-(tot-1)*yGap/2;
    list.forEach((bn,i)=>{ placeBranch(bn.id, cx+dir*210, curY+lv[i]*yGap/2, dir); curY+=lv[i]*yGap; });
  }
  placeSide(right, 1);
  placeSide(left, -1);
}

// ── PARTIAL LAYOUT (branch only) ────────────────────────────────────
function applyPartialLayout(rootId,layoutType){
  const root=gn(rootId);if(!root)return;
  // Collect branch node IDs
  const brIds=new Set();brIds.add(rootId);
  function collectD(id){kids(id).forEach(c=>{brIds.add(c.id);collectD(c.id);});}
  collectD(rootId);
  // Snapshot colors
  const colorSnap=snapshotLayoutColors();
  // Anchor position
  const ax=root.x,ay=root.y;
  snap();
  // Count leaves within branch
  function cntL(id){const ch=kids(id).filter(c=>brIds.has(c.id));return ch.length?ch.reduce((s,c)=>s+cntL(c.id),0):1;}

  if(layoutType==='radial'){
    (function plR(nid,d,sa,as){
      const ch=kids(nid).filter(c=>brIds.has(c.id));if(!ch.length)return;
      const r2=160+d*130;
      const lv=ch.map(c=>cntL(c.id));const tot=lv.reduce((a,b)=>a+b,0);
      const totalAng=Math.min(Math.PI*2,Math.max(as,tot*0.45));
      let curAng=sa-totalAng/2;
      ch.forEach((c,i)=>{const share=(lv[i]/tot)*totalAng;const a=curAng+share/2;
        c.x=gn(nid).x+Math.cos(a)*r2;c.y=gn(nid).y+Math.sin(a)*r2;
        plR(c.id,d+1,a,share);curAng+=share;});
    })(rootId,0,-Math.PI/2,Math.PI*2);
  } else if(layoutType==='tree-h'){
    const xG=220,yG=75;
    (function place(id,depth,yC){
      const n=gn(id);if(!n)return;n.x=ax+depth*xG;n.y=yC;
      const ch=kids(id).filter(c=>brIds.has(c.id));if(!ch.length)return;
      const lv=ch.map(c=>cntL(c.id));const tot=lv.reduce((a,b)=>a+b,0);
      let curY=yC-(tot-1)*yG/2;
      ch.forEach((c,i)=>{place(c.id,depth+1,curY+lv[i]*yG/2);curY+=lv[i]*yG;});
    })(rootId,0,ay);
  } else if(layoutType==='tree-v'){
    const yG=140,xG=190;
    (function place(id,depth,xC){
      const n=gn(id);if(!n)return;n.x=xC;n.y=ay+depth*yG;
      const ch=kids(id).filter(c=>brIds.has(c.id));if(!ch.length)return;
      const lv=ch.map(c=>cntL(c.id));const tot=lv.reduce((a,b)=>a+b,0);
      let curX=xC-(tot-1)*xG/2;
      ch.forEach((c,i)=>{place(c.id,depth+1,curX+lv[i]*xG/2);curX+=lv[i]*xG;});
    })(rootId,0,ax);
  } else if(layoutType==='lr'){
    const ch=kids(rootId).filter(c=>brIds.has(c.id));
    const sorted=[...ch].sort((a,b)=>cntL(b.id)-cntL(a.id));
    const right2=[],left2=[];
    sorted.forEach((n,i)=>{if(i%2===0)right2.push(n);else left2.push(n);});
    const yG=75,xS=190;
    function plB(id,px,py,dir){const n=gn(id);if(!n)return;n.x=px;n.y=py;
      const ch2=kids(id).filter(c=>brIds.has(c.id));if(!ch2.length)return;
      const lv=ch2.map(c=>cntL(c.id));const tot=lv.reduce((a,b)=>a+b,0);
      let curY=py-(tot-1)*yG/2;
      ch2.forEach((c,i)=>{plB(c.id,px+dir*xS,curY+lv[i]*yG/2,dir);curY+=lv[i]*yG;});}
    function plS(list,dir){const lv=list.map(n=>cntL(n.id));const tot=lv.reduce((a,b)=>a+b,0);
      let curY=ay-(tot-1)*yG/2;
      list.forEach((bn,i)=>{plB(bn.id,ax+dir*210,curY+lv[i]*yG/2,dir);curY+=lv[i]*yG;});}
    plS(right2,1);plS(left2,-1);
  }
  // Collision relaxation within branch only
  const bNodes=nodes.filter(n=>brIds.has(n.id));
  for(let it=0;it<50;it++){for(let i=0;i<bNodes.length;i++){for(let j=i+1;j<bNodes.length;j++){
