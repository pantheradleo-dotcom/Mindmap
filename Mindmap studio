const TEMPLATES_USER_KEY = 'mindmap-studio-user-templates';

function getUserTemplates() {
  try { const r=localStorage.getItem(TEMPLATES_USER_KEY); return r?JSON.parse(r):[]; }
  catch { return []; }
}
function saveUserTemplates(tpls) {
  try { localStorage.setItem(TEMPLATES_USER_KEY, JSON.stringify(tpls)); } catch {}
}
function allTemplates() {
  const ut = getUserTemplates();
  return [...TEMPLATES, ...ut];
}

// Build categories from both built-in and user templates
function getCategories() {
  return ['Tous', ...[...new Set(allTemplates().map(t=>t.cat))]];
}

const CATEGORIES=['Tous',...[...new Set(TEMPLATES.map(t=>t.cat))]];
let activeCat='Tous';

function previewSVG(tpl){
  // Generate a tiny SVG preview based on the template color & structure
  const c=tpl.color;
  const dots=[{x:50,y:50,r:12,fill:c},{x:18,y:24,r:7,fill:c+'cc'},{x:82,y:24,r:7,fill:c+'cc'},{x:18,y:75,r:7,fill:c+'cc'},{x:82,y:75,r:7,fill:c+'cc'}];
  const lines=[[50,50,18,24],[50,50,82,24],[50,50,18,75],[50,50,82,75]];
  let svg=`<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" style="background:transparent">`;
  lines.forEach(([x1,y1,x2,y2])=>{svg+=`<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="${c}" stroke-width="1.5" stroke-opacity="0.5"/>`});
  dots.forEach(d=>{svg+=`<circle cx="${d.x}" cy="${d.y}" r="${d.r}" fill="${d.fill}" fill-opacity="0.85"/>`;});
  svg+=`<text x="50" y="53" text-anchor="middle" font-size="8" font-family="Inter,sans-serif" fill="white" font-weight="600">${tpl.emoji}</text>`;
  svg+='</svg>';
  return svg;
}

function renderGallery(){
  const grid=document.getElementById('tpl-grid');
  grid.innerHTML='';
  const all=allTemplates();
  const filtered=activeCat==='Tous'?all:all.filter(t=>t.cat===activeCat);
  filtered.forEach(tpl=>{
    const isUser=!!tpl._user;
    const card=document.createElement('div');
    card.className='tpl-card'+(tpl.id==='blank'?' blank':'')+(isUser?' tpl-card-user':'');
    const badgeColor={Général:'#5b6af0',Stratégie:'#a855f7',Analyse:'#f0a500',Gestion:'#0ea5e9',Créativité:'#f97316',Éducation:'#e85d7a'}[tpl.cat]||'#2cb67d';
    card.innerHTML=`
      <div class="tpl-preview">${tpl.id==='blank'?`<div class="tpl-blank-icon">✦</div>`:previewSVG(tpl)}</div>
      <div class="tpl-info">
        <div class="tpl-name">${tpl.name}${isUser?'<span style="font-size:9px;margin-left:5px;color:var(--ok)">✦ perso</span>':''}</div>
        <div class="tpl-desc">${tpl.desc||''}</div>
        <span class="tpl-badge" style="background:${badgeColor}22;color:${badgeColor};border:1px solid ${badgeColor}44">${tpl.cat}</span>
      </div>`;
    if(isUser){
      const delBtn=document.createElement('div');delBtn.className='tpl-del';delBtn.textContent='✕';delBtn.title='Supprimer ce template';
      delBtn.addEventListener('click',e=>{
        e.stopPropagation();
        if(!confirm('Supprimer le template "'+tpl.name+'" ?'))return;
        const ut=getUserTemplates().filter(t=>t.id!==tpl.id);
        saveUserTemplates(ut);renderGallery();renderCats();
        toast('Template supprimé','ok');
      });
      card.appendChild(delBtn);
    }
    card.addEventListener('click',()=>applyTemplate(tpl));
    grid.appendChild(card);
  });
}

