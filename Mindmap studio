// ── KEYBOARD ──────────────────────────────────────────────────────────────
document.addEventListener('keydown',e=>{
  const skip=e.target===ni||e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA';
  if(!skip&&e.code==='Space'){e.preventDefault();spaceDown=true;cv.style.cursor='grab';return;}
  if(!skip&&(e.ctrlKey||e.metaKey)&&e.key==='z'){e.preventDefault();undo();return;}
  if(!skip&&(e.ctrlKey||e.metaKey)&&(e.key==='y'||(e.shiftKey&&e.key==='z'))){e.preventDefault();redo();return;}
  if(!skip&&(e.ctrlKey||e.metaKey)&&e.key==='c'){e.preventDefault();copyNodes();return;}
  if(!skip&&(e.ctrlKey||e.metaKey)&&e.key==='v'){e.preventDefault();pasteNodes();return;}
  if(!skip&&(e.ctrlKey||e.metaKey)&&e.key==='d'){e.preventDefault();copyNodes();pasteNodes();return;}
  if(!skip&&(e.key==='f'||e.key==='F')){fitView();return;}
  if(!skip&&(e.key==='v'||e.key==='V')){setTool('select');return;}
  if(!skip&&(e.key==='h'||e.key==='H')){setTool('pan');return;}
  if(!skip&&(e.key==='t'||e.key==='T')&&!e.ctrlKey){openGallery();return;}
  if(!skip&&e.key==='F2'&&selId){startEdit(selId);return;}
  if(!skip&&e.key==='Tab'&&selId){e.preventDefault();addChild(selId);return;}
  if(!skip&&e.key==='Enter'&&selId){e.preventDefault();const n=gn(selId);if(!n)return;snap();const s=mkNode('Nouvelle idée',n.x,n.y+70,n.depth,n.parentId,n.color||branchColor(n));if(n.parentId)addConn(n.parentId,s.id,'h');selId=s.id;selectedIds=new Set([s.id]);render();mmR();posFtb();startEdit(s.id);return;}
  if(!skip&&(e.key==='Delete'||e.key==='Backspace')&&selId){snap();rmNode(selId);selId=null;selectedIds.clear();hideFtb();render();mmR();return;}
  if(e.key==='Escape'){hideCM();if(connFrom){connFrom=null;connMouse=null;render();}if(!skip){si.value='';doSearch('');}}
});
