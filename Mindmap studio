document.addEventListener('keydown',e=>{
  const skip=e.target===ni||e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA';
  if(!skip&&e.code==='Space'){e.preventDefault();spaceDown=true;cv.style.cursor='grab';return;}
  if(!skip&&(e.ctrlKey||e.metaKey)&&e.key==='z'){e.preventDefault();undo();return;}
  if(!skip&&(e.ctrlKey||e.metaKey)&&(e.key==='y'||(e.shiftKey&&e.key==='z'))){e.preventDefault();redo();return;}
  if(!skip&&(e.ctrlKey||e.metaKey)&&e.key==='c'){e.preventDefault();copyNodes();return;}
  if(!skip&&(e.ctrlKey||e.metaKey)&&e.key==='v'){e.preventDefault();pasteNodes();return;}
  if(!skip&&(e.ctrlKey||e.metaKey)&&e.key==='d'){e.preventDefault();copyNodes();pasteNodes();return;}
  if(!skip&&(e.key==='f'||e.key==='F')&&!e.ctrlKey){fitView();return;}
  if(!skip&&(e.key==='v'||e.key==='V')){setTool('select');return;}
  if(!skip&&(e.key==='h'||e.key==='H')){setTool('pan');return;}
  if(!skip&&(e.key==='t'||e.key==='T')&&!e.ctrlKey){openGallery();return;}
  if(!skip&&(e.key==='n'||e.key==='N')&&!e.ctrlKey){setTool('sticky');return;}
  if(!skip&&(e.key==='r'||e.key==='R')&&!e.ctrlKey){setTool('rect');return;}
  if(!skip&&(e.key==='e'||e.key==='E')&&!e.ctrlKey){setTool('ellipse');return;}
  if(!skip&&(e.key==='x'||e.key==='X')&&!e.ctrlKey){setTool('freetext');return;}
  if(!skip&&(e.key==='g'||e.key==='G')&&!e.ctrlKey){setTool('frame');return;}
  if(!skip&&e.key==='F2'&&selId){startEdit(selId);return;}
  if(!skip&&e.key==='Tab'&&selId){e.preventDefault();addChild(selId);return;}
  if(!skip&&e.key==='Enter'&&selId){e.preventDefault();const n=gn(selId);if(!n)return;snap();
  if(!n.parentId){
    // Root node → create child instead of orphan sibling
    addChild(selId);
  } else {
    const siblingColor=colorMode===COLOR_MODES.FREE?(n.color||branchColor(n)):getBranchColorVariant(branchColor(gn(n.parentId)||n),n.depth,((gn(n.parentId)?kids(n.parentId):[]).length||0),colorMode);const s=mkNode('Nouvelle idée',n.x,n.y+70,n.depth,n.parentId,siblingColor);
    addConn(n.parentId,s.id,'h');
    selId=s.id;selectedIds=new Set([s.id]);render();mmR();posFtb();startEdit(s.id);
  }
  return;}
  if(!skip&&(e.key==='Delete'||e.key==='Backspace')){
    if(selConnId){snap();conns=conns.filter(x=>x.id!==selConnId);selConnId=null;render();mmR();toast('Connexion supprimée','ok');return;}
    if(selShapeId){snap();shapes=shapes.filter(s=>s.id!==selShapeId);selShapeId=null;render();mmR();return;}
    if(selFrameId){snap();frames=frames.filter(f=>f.id!==selFrameId);selFrameId=null;render();mmR();return;}
    if(selId){snap();rmNode(selId);selId=null;selectedIds.clear();hideFtb();hideShapeFtb();hideFrameFtb();selShapeId=null;selFrameId=null;selConnId=null;render();mmR();return;}
  }
  if(e.key==='Escape'){hideCM();hideShapeFtb();hideFrameFtb();selShapeId=null;selFrameId=null;selConnId=null;if(connFrom){connFrom=null;connMouse=null;render();}if(!skip){si.value='';doSearch('');}}
});
