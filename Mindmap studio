      const tt=i/20,u=1-tt;
      const bx=u*u*u*sx+3*u*u*tt*cp1x+3*u*tt*tt*cp2x+tt*tt*tt*tx;
      const by=u*u*u*sy+3*u*u*tt*cp1y+3*u*tt*tt*cp2y+tt*tt*tt*ty;
      if(Math.hypot(wx-bx,wy-by)<THRESH)return conn;
    }
  }
  return null;
}

function drawConn(src,tgt,type){
  const col=type==='s'?'#f0a500':branchColor(src);const style=src.connStyle||'solid';
  let lw=src.depth===0?4:src.depth===1?3:2;if(style==='thick')lw*=2;
  // Start from source border toward target center, end at target border toward source center
  const sp=nodeBorderPt(src,tgt.x,tgt.y);
  const tp=nodeBorderPt(tgt,src.x,src.y);
  const sx=sp.x,sy=sp.y,tx=tp.x,ty=tp.y,dx=tx-sx,dy=ty-sy;
  // Control points: pull perpendicular to midpoint for natural curve
  const mx=(sx+tx)/2, my=(sy+ty)/2;
  const cp1x=sx+dx*.45, cp1y=sy;
  const cp2x=tx-dx*.45, cp2y=ty;
  const isSel = src.id && selConnId && conns.find(cc=>cc.id===selConnId&&((cc.s===src.id&&cc.t===tgt.id)||(cc.s===tgt.id&&cc.t===src.id)));
  ctx.beginPath();ctx.moveTo(sx,sy);ctx.bezierCurveTo(cp1x,cp1y,cp2x,cp2y,tx,ty);
  if(isSel){ctx.setLineDash([]);ctx.strokeStyle=getComputedStyle(document.documentElement).getPropertyValue('--acc').trim()||'#5b6af0';ctx.lineWidth=(lw+2)/scale*scale;ctx.lineCap='round';ctx.stroke();}
  else{if(style==='dashed')ctx.setLineDash([8,4]);else if(style==='dotted')ctx.setLineDash([2,3]);else if(type==='s')ctx.setLineDash([5,4]);else ctx.setLineDash([]);
  ctx.strokeStyle=type==='s'?col+'bb':col+(isDark?'99':'88');ctx.lineWidth=type==='s'?1.5:lw;ctx.lineCap='round';ctx.stroke();ctx.setLineDash([]);}
  if(style==='arrow'){const ang=Math.atan2(ty-sy,tx-sx),sz=8;ctx.beginPath();ctx.moveTo(tx,ty);ctx.lineTo(tx-sz*Math.cos(ang-Math.PI/6),ty-sz*Math.sin(ang-Math.PI/6));ctx.lineTo(tx-sz*Math.cos(ang+Math.PI/6),ty-sz*Math.sin(ang+Math.PI/6));ctx.closePath();ctx.fillStyle=col;ctx.fill();}
}

function drawNode(n){
  const isSel=n.id===selId||selectedIds.has(n.id),isHov=n.id===hovId;
  const col=branchColor(n);const isRoot=!n.parentId;const isPreview=previewColorsActive&&previewColorMap.has(n.id);
  let animScale=1,animOX=0,animOY=0;
  if(n._anim){animScale=n._anim.scale;animOX=n._anim.ox;animOY=n._anim.oy;}
  if(animScale<.01)return;
  ctx.save();
  if(n._anim){ctx.translate(animOX*(1-animScale)+n.x*animScale,animOY*(1-animScale)+n.y*animScale);ctx.scale(animScale,animScale);ctx.translate(-n.x,-n.y);}
  const x=n.x-n.width/2,y=n.y-n.height/2,r=n.shape==='pill'?n.height/2:n.shape==='rect'?8:0;
  const isHit=searchQ&&searchHits.includes(n.id),isCurHit=isHit&&searchHits[searchIdx]===n.id,isNoteHit=searchNoteHits.has(n.id);
  if(isRoot){ctx.shadowColor=col+'44';ctx.shadowBlur=22;ctx.shadowOffsetY=5;}
  else if(isSel){ctx.shadowColor=col+'33';ctx.shadowBlur=14;ctx.shadowOffsetY=3;}
  else if(isPreview){ctx.shadowColor=col+'2f';ctx.shadowBlur=10;ctx.shadowOffsetY=2;}
  else if(isHov){ctx.shadowColor='rgba(0,0,0,.08)';ctx.shadowBlur=8;ctx.shadowOffsetY=2;}
  if(n.shape==='hex')drawHex(ctx,n.x,n.y,n.width/2+2,n.height/2+2);
  else{ctx.beginPath();ctx.roundRect(x,y,n.width,n.height,r);}
  if(isRoot||n.depth===1)ctx.fillStyle=n.fillColor||col;
  else ctx.fillStyle=(n.fillColor||col)+(isDark?'2a':'1c');
  ctx.fill();ctx.shadowBlur=0;ctx.shadowOffsetY=0;
  if(n.shape==='hex')drawHex(ctx,n.x,n.y,n.width/2+2,n.height/2+2);
  else{ctx.beginPath();ctx.roundRect(x,y,n.width,n.height,r);}
  if(isRoot||n.depth===1)ctx.strokeStyle='transparent';
  else{ctx.strokeStyle=isSel?col:isHov?col+'99':col+'44';ctx.lineWidth=isSel?2:1.5;ctx.stroke();}
  if(selectedIds.has(n.id)&&selectedIds.size>1){ctx.beginPath();ctx.roundRect(x-3,y-3,n.width+6,n.height+6,r+3);ctx.strokeStyle=col;ctx.lineWidth=2;ctx.setLineDash([3,2]);ctx.stroke();ctx.setLineDash([]);}
  if(isHit){if(n.shape==='hex')drawHex(ctx,n.x,n.y,n.width/2+7,n.height/2+7);else{ctx.beginPath();ctx.roundRect(x-4,y-4,n.width+8,n.height+8,r+4);}if(isNoteHit){ctx.strokeStyle=isCurHit?'#0ea5e9':'#0ea5e955';}else{ctx.strokeStyle=isCurHit?'#f0a500':'#f0a50055';}ctx.lineWidth=2.5;ctx.setLineDash(isCurHit?[]:[4,3]);ctx.stroke();ctx.setLineDash([]);}
  const label=(n.emoji?n.emoji+' ':'')+n.text;
  ctx.font=`${n.fontWeight||500} ${n.fontSize||13}px Inter,sans-serif`;
  ctx.fillStyle=(isRoot||n.depth===1)?bestTextColor(col):(isDark?'#e4e8f8':'#1a1d2e');
  ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(label,n.x+2,n.y,n.width-PX*2);
  if((n.tags||[]).length&&!isRoot){const tagY=n.y+n.height/2+8;let tx2=n.x-(n.tags.length*28)/2;n.tags.slice(0,3).forEach(tag=>{const c=tc(allTags.indexOf(tag));ctx.fillStyle=c;ctx.beginPath();ctx.roundRect(tx2,tagY-5,28,10,5);ctx.fill();ctx.fillStyle='#fff';ctx.font='bold 6px Inter,sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(tag.slice(0,4),tx2+14,tagY+.5);tx2+=30;});}
  if(n.note){ctx.beginPath();ctx.arc(n.x+n.width/2-5,y+5,4,0,Math.PI*2);ctx.fillStyle='#f0a500';ctx.fill();ctx.strokeStyle='#fff';ctx.lineWidth=1.2;ctx.stroke();}
  if(n.url){ctx.beginPath();ctx.arc(n.x-n.width/2+8,y+8,5,0,Math.PI*2);ctx.fillStyle='#0ea5e9';ctx.fill();}
  if(n.mapLink){ctx.beginPath();ctx.arc(n.x-n.width/2+8,n.y-n.height/2+8+(n.url?12:0),5,0,Math.PI*2);ctx.fillStyle='#f0a500';ctx.fill();ctx.font='7px Inter,sans-serif';ctx.fillStyle='#fff';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('↗',n.x-n.width/2+8,n.y-n.height/2+8.5+(n.url?12:0));}
  if(hasKids(n.id)){const bx=n.x+n.width/2+13,by=n.y;ctx.beginPath();ctx.arc(bx,by,7,0,Math.PI*2);ctx.fillStyle=isDark?col+'44':col+'22';ctx.fill();ctx.strokeStyle=col;ctx.lineWidth=1.5;ctx.stroke();ctx.fillStyle=col;ctx.font='bold 9px Inter,sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(n.collapsed?'+':'-',bx,by+.5);}
  if(isHov&&activeTool==='select'){ctx.beginPath();ctx.arc(n.x+n.width/2,n.y,5,0,Math.PI*2);ctx.fillStyle=col;ctx.strokeStyle='#fff';ctx.lineWidth=1.5;ctx.fill();ctx.stroke();}
  if(isColorLocked(n)) drawColorLockBadge(ctx,n);
  ctx.restore();
}
function drawColorLockBadge(ctx,node){
  const bx=node.x+node.width/2-10, by=node.y-node.height/2+10;
  ctx.save();
  ctx.beginPath(); ctx.arc(bx,by,6,0,Math.PI*2); ctx.fillStyle=isDark?'rgba(12,14,20,.78)':'rgba(255,255,255,.96)'; ctx.fill();
  ctx.strokeStyle=branchColor(node); ctx.lineWidth=1; ctx.stroke();
  ctx.font='8px Inter,sans-serif'; ctx.textAlign='center'; ctx.textBaseline='middle'; ctx.fillStyle=branchColor(node); ctx.fillText('🔒',bx,by+.5);
  ctx.restore();
}
function drawHex(c,cx,cy,rx,ry){c.beginPath();for(let i=0;i<6;i++){const a=Math.PI/3*i-Math.PI/6;c.lineTo(cx+rx*Math.cos(a),cy+ry*Math.sin(a));}c.closePath();}

// ── MINIMAP ───────────────────────────────────────────────────────────────
function mmR(){
  const W=mmc.width,H=mmc.height;mmctx.clearRect(0,0,W,H);
  mmctx.fillStyle=isDark?'#0c0e14':'#edf0f6';mmctx.fillRect(0,0,W,H);
  const vis=nodes.filter(n=>!isHidden(n.id));if(!vis.length)return;
  let mnX=Infinity,mnY=Infinity,mxX=-Infinity,mxY=-Infinity;
  vis.forEach(n=>{mnX=Math.min(mnX,n.x-n.width/2);mnY=Math.min(mnY,n.y-n.height/2);mxX=Math.max(mxX,n.x+n.width/2);mxY=Math.max(mxY,n.y+n.height/2);});
  const pad=16,ms=Math.min(W/(mxX-mnX+pad*2),H/(mxY-mnY+pad*2));
  const ofx=W/2-(mnX+(mxX-mnX)/2)*ms,ofy=H/2-(mnY+(mxY-mnY)/2)*ms;
  for(const c of conns){const s=gn(c.s),t=gn(c.t);if(!s||!t||isHidden(c.s)||isHidden(c.t))continue;mmctx.beginPath();mmctx.moveTo(s.x*ms+ofx,s.y*ms+ofy);mmctx.lineTo(t.x*ms+ofx,t.y*ms+ofy);mmctx.strokeStyle=isDark?'#ffffff0f':'#00000010';mmctx.lineWidth=1;mmctx.stroke();}
  // Draw frames in minimap
  frames.forEach(f=>{mmctx.strokeStyle=(f.color||'#5b6af0')+'44';mmctx.lineWidth=1;mmctx.strokeRect(f.x*ms+ofx,f.y*ms+ofy,f.width*ms,f.height*ms);});
  // Draw shapes in minimap
  shapes.forEach(s=>{mmctx.fillStyle=(s.color||s.strokeColor||'#f0a500')+'55';mmctx.fillRect(s.x*ms+ofx-s.width*ms/2,s.y*ms+ofy-s.height*ms/2,s.width*ms,s.height*ms);});
  vis.forEach(n=>{mmctx.fillStyle=branchColor(n)+'bb';mmctx.beginPath();mmctx.roundRect(n.x*ms+ofx-n.width*ms/2,n.y*ms+ofy-3,n.width*ms,6,2);mmctx.fill();});
  const vpX=(-viewX/scale)*ms+ofx,vpY=(-viewY/scale)*ms+ofy,vpW=(cv.width/scale)*ms,vpH=(cv.height/scale)*ms;
  mmVP.style.left=Math.max(0,vpX)+'px';mmVP.style.top=Math.max(0,vpY)+'px';mmVP.style.width=Math.min(W,vpW)+'px';mmVP.style.height=Math.min(H,vpH)+'px';
}

