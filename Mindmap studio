// ── INLINE EDIT ───────────────────────────────────────────────────────────
function startEdit(id){const n=gn(id);if(!n)return;editId=id;const p=w2c(n.x-n.width/2,n.y-n.height/2);const r=cwEl().getBoundingClientRect();ni.style.display='block';ni.style.left=(p.x+r.left)+'px';ni.style.top=(p.y+HH)+'px';ni.style.width=Math.max(n.width*scale,110)+'px';ni.style.fontSize=(n.fontSize||13)*scale+'px';ni.value=n.text;ni.focus();ni.select();}
let _committing=false;
function commitEdit(){
  if(!editId||_committing)return;
  _committing=true;
  const n=gn(editId);
  if(n&&ni.value.trim()){snap();n.text=ni.value.trim();measure(n);}
  editId=null;ni.style.display='none';
  render();mmR();
  _committing=false;
}
ni.addEventListener('keydown',e=>{
  if(e.key==='Enter'){e.preventDefault();commitEdit();}
  if(e.key==='Escape'){editId=null;ni.style.display='none';render();}
});
ni.addEventListener('blur',()=>commitEdit());

// ── MOUSE ─────────────────────────────────────────────────────────────────
let lastHov=0;
function nodeAt(wx,wy){for(let i=nodes.length-1;i>=0;i--){const n=nodes[i];if(isHidden(n.id))continue;if(wx>=n.x-n.width/2&&wx<=n.x+n.width/2&&wy>=n.y-n.height/2&&wy<=n.y+n.height/2)return n;}return null;}

cv.addEventListener('mousemove',e=>{
  const now=Date.now();const wx=cli2w(e.clientX,e.clientY).x,wy=cli2w(e.clientX,e.clientY).y;
  if(dragId){
    const n=gn(dragId);if(n){const dx=wx-dragOX-n.x,dy=wy-dragOY-n.y;n.x+=dx;n.y+=dy;multiDragOffsets.forEach((off,sid)=>{if(sid!==dragId){const sn=gn(sid);if(sn){sn.x+=dx;sn.y+=dy;}}});}
    dragOX=wx-gn(dragId).x;dragOY=wy-gn(dragId).y;
    posFtb();render();mmR();return;
  }
  if(panning){const r=cwEl().getBoundingClientRect();viewX=e.clientX-r.left-panSX;viewY=e.clientY-HH-panSY;render();mmR();return;}
  if(connFrom){connMouse={x:wx,y:wy};render();return;}
  if(selRectStart){selRect={sx:selRectStart.x,sy:selRectStart.y,ex:wx,ey:wy};render();return;}
  if(now-lastHov>25){lastHov=now;const n=nodeAt(wx,wy);const nid=n?n.id:null;if(nid!==hovId){hovId=nid;render();}if(n){if(onCollBtn(n,wx,wy))cv.style.cursor='pointer';else if(onEdge(n,wx,wy))cv.style.cursor='crosshair';else cv.style.cursor='grab';}else cv.style.cursor=(activeTool==='pan'||spaceDown)?'grab':'default';}
});

cv.addEventListener('mousedown',e=>{
  e.preventDefault();hideCM();urlpop.classList.remove('v');
  const wx=cli2w(e.clientX,e.clientY).x,wy=cli2w(e.clientX,e.clientY).y;const n=nodeAt(wx,wy);
  if(e.button===2){if(n){ctxId=n.id;selId=n.id;selectedIds=new Set([n.id]);cm.style.display='block';cm.style.left=Math.min(e.clientX,window.innerWidth-200)+'px';cm.style.top=Math.min(e.clientY,window.innerHeight-200)+'px';render();posFtb();}return;}
  if(activeTool==='pan'||spaceDown){panning=true;const r=cwEl().getBoundingClientRect();panSX=e.clientX-r.left-viewX;panSY=e.clientY-HH-viewY;return;}
  if(n){
    if(n.url&&Math.hypot(wx-n.x+n.width/2-8,wy-n.y+n.height/2-8)<=7){window.open(n.url,'_blank');return;}
    if(onCollBtn(n,wx,wy)){toggleCollapse(n.id);return;}
    if(onEdge(n,wx,wy)){connFrom=n.id;connMouse={x:wx,y:wy};return;}
    dragId=n.id;dragOX=wx-n.x;dragOY=wy-n.y;
    if(e.shiftKey){selectedIds.has(n.id)?selectedIds.delete(n.id):selectedIds.add(n.id);}
    else{if(!selectedIds.has(n.id)){selId=n.id;selectedIds=new Set([n.id]);}}
    selId=n.id;
    multiDragOffsets.clear();selectedIds.forEach(sid=>{const sn=gn(sid);if(sn)multiDragOffsets.set(sid,{dx:sn.x-n.x,dy:sn.y-n.y});});
    render();posFtb();
  }else{
    selId=null;selectedIds.clear();hideFtb();
    if(activeTool==='select'){selRectStart={x:wx,y:wy};selRect={sx:wx,sy:wy,ex:wx,ey:wy};}
    else{panning=true;const r=cwEl().getBoundingClientRect();panSX=e.clientX-r.left-viewX;panSY=e.clientY-HH-viewY;}
    render();
  }
});

cv.addEventListener('mouseup',e=>{
  if(connFrom){const wx=cli2w(e.clientX,e.clientY).x,wy=cli2w(e.clientX,e.clientY).y;const t=nodeAt(wx,wy);if(t&&t.id!==connFrom){snap();addConn(connFrom,t.id,'h');toast('Connexion créée','ok');render();mmR();}connFrom=null;connMouse=null;render();return;}
  if(selRectStart&&selRect){
    const{sx,sy,ex,ey}=selRect;const mnX=Math.min(sx,ex),mxX=Math.max(sx,ex),mnY=Math.min(sy,ey),mxY=Math.max(sy,ey);
    const hit=nodes.filter(n=>!isHidden(n.id)&&n.x>=mnX&&n.x<=mxX&&n.y>=mnY&&n.y<=mxY);
    if(hit.length){selId=hit[0].id;selectedIds=new Set(hit.map(n=>n.id));if(hit.length===1)posFtb();else toast(hit.length+' nœuds sélectionnés','in');}
    selRectStart=null;selRect=null;render();return;
  }
  if(dragId)snap();dragId=null;panning=false;selRectStart=null;selRect=null;
});

