// ── Thumbnail generator ───────────────────────────────────────────────
function mapThumbSVG(map) {
  const ns = map.nodes || [];
  const cs = map.conns || [];
  if(!ns.length) return '<svg viewBox="0 0 195 108" xmlns="http://www.w3.org/2000/svg"><text x="97" y="58" text-anchor="middle" font-size="11" font-family="Inter,sans-serif" fill="#9aa0bf">Carte vide</text></svg>';
  // Compute bounding box
  let mnX=Infinity,mnY=Infinity,mxX=-Infinity,mxY=-Infinity;
  ns.forEach(n=>{mnX=Math.min(mnX,n.x-(n.width||60)/2);mnY=Math.min(mnY,n.y-18);mxX=Math.max(mxX,n.x+(n.width||60)/2);mxY=Math.max(mxY,n.y+18);});
  const W=195,H=108,pad=14;
  const scx=(W-pad*2)/(mxX-mnX||1), scy=(H-pad*2)/(mxY-mnY||1);
  const sc=Math.min(scx,scy,1.2);
  const ox=W/2-((mnX+mxX)/2)*sc, oy=H/2-((mnY+mxY)/2)*sc;
  const tx=(x)=>x*sc+ox, ty=(y)=>y*sc+oy;
  // Build palette map
  const PAL_THUMB = map.palette ? (PALETTES.find(p=>p.id===map.palette)||PALETTES[0]).colors : PALETTES[0].colors;
  function nc(n){if(!n.parentId)return n.color||PAL_THUMB[0];let cur=n;while(cur.parentId){const p=ns.find(x=>x.id===cur.parentId);if(!p)break;if(!p.parentId)return cur.color||p.color||PAL_THUMB[0];cur=p;}return n.color||PAL_THUMB[0];}
  let svg = `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg">`;
  // Connections
  cs.slice(0,30).forEach(con=>{
    const s=ns.find(n=>n.id===con.s), t=ns.find(n=>n.id===con.t);
    if(!s||!t)return;
    const col=nc(s);
    const dx=tx(t.x)-tx(s.x);
    svg+=`<path d="M${tx(s.x)} ${ty(s.y)} C${tx(s.x)+dx*.45} ${ty(s.y)} ${tx(t.x)-dx*.45} ${ty(t.y)} ${tx(t.x)} ${ty(t.y)}" fill="none" stroke="${col}" stroke-opacity="0.6" stroke-width="${s.depth===0?2.5:s.depth===1?1.8:1.2}" stroke-linecap="round"/>`;
  });
  // Nodes
  ns.slice(0,40).forEach(n=>{
    const col=nc(n);const isRoot=!n.parentId;
    const w=Math.max((n.width||60)*sc*0.85,isRoot?40:20),h=isRoot?16:11;
    const x=tx(n.x)-w/2,y=ty(n.y)-h/2;
    if(isRoot||n.depth===1){svg+=`<rect x="${x}" y="${y}" width="${w}" height="${h}" rx="${h/2}" fill="${col}"/>`;}
    else{svg+=`<rect x="${x}" y="${y}" width="${w}" height="${h}" rx="${h/2}" fill="${col}22" stroke="${col}" stroke-width="0.8"/>`;}
  });
  svg+='</svg>';
  return svg;
}

function formatDate(ts) {
  if(!ts) return '';
  const d=new Date(ts), now=new Date();
  const diff=now-d;
  if(diff<60000) return "À l'instant";
  if(diff<3600000) return Math.floor(diff/60000)+'min';
  if(diff<86400000) return Math.floor(diff/3600000)+'h';
  if(diff<7*86400000) return Math.floor(diff/86400000)+'j';
  return d.toLocaleDateString('fr-FR',{day:'numeric',month:'short'});
}

function escHtml(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

// ── Render grid ───────────────────────────────────────────────────────
function renderMapsGrid(filter) {
  const grid = document.getElementById('maps-grid');
  const store = getMapsStore();
  let maps = [...store.maps].sort((a,b)=>b.ts-a.ts);
  if(filter) maps = maps.filter(m=>m.name.toLowerCase().includes(filter.toLowerCase()));
  grid.innerHTML = '';

  // New map card
  const newCard = document.createElement('div');
  newCard.className = 'map-card-new';
  newCard.innerHTML = '<div class="map-card-new-icon">＋</div><div class="map-card-new-label">Nouvelle carte</div>';
  newCard.addEventListener('click', ()=>{
    const name = prompt('Nom de la nouvelle carte :', 'Nouvelle carte');
    if(name===null) return;
    createNewMap(name.trim()||'Nouvelle carte');
    closeMapsManager();
    toast('Carte créée', 'ok');
  });
  grid.appendChild(newCard);

  maps.forEach(map=>{
    const isActive = map.id === currentMapId;
    const card = document.createElement('div');
    card.className = 'map-card'+(isActive?' active':'');

    // Thumbnail
    const thumb = document.createElement('div');
    thumb.className = 'map-thumb';
    thumb.innerHTML = mapThumbSVG(map);
    if(isActive){
      const badge=document.createElement('div');badge.className='map-thumb-badge';badge.textContent='En cours';
      thumb.appendChild(badge);
    }

    // Info
    const info = document.createElement('div');
    info.className = 'map-info';
    const nodeCount = (map.nodes||[]).length;
    info.innerHTML = `<div class="map-name">${escHtml(map.name)}</div>
      <div class="map-meta">${nodeCount} nœud${nodeCount!==1?'s':''} · ${formatDate(map.ts)}</div>`;

    // Actions row
    const actions = document.createElement('div');
    actions.className = 'map-actions';

    if(!isActive){
      const btnOpen = document.createElement('button');
      btnOpen.className = 'map-act open-btn';btnOpen.textContent = '→ Ouvrir';
      btnOpen.addEventListener('click', e=>{e.stopPropagation();loadMap(map.id);closeMapsManager();toast('Carte chargée : '+map.name,'ok');});
      actions.appendChild(btnOpen);
    }

    const btnRename = document.createElement('button');
    btnRename.className = 'map-act';btnRename.textContent = '✎ Renommer';
    btnRename.addEventListener('click', e=>{
      e.stopPropagation();
      const newName = prompt('Nouveau nom :', map.name);
      if(!newName||!newName.trim()) return;
      renameMap(map.id, newName.trim());
      renderMapsGrid(document.getElementById('maps-search-input').value);
      toast('Renommée','ok');
    });
    actions.appendChild(btnRename);

    const btnDupe = document.createElement('button');
    btnDupe.className = 'map-act';btnDupe.textContent = '⊕ Dupliquer';
    btnDupe.addEventListener('click', e=>{
      e.stopPropagation();
      duplicateMap(map.id);
      renderMapsGrid(document.getElementById('maps-search-input').value);
      toast('Carte dupliquée','ok');
    });
    actions.appendChild(btnDupe);

    const btnDel = document.createElement('button');
    btnDel.className = 'map-act danger';btnDel.textContent = '✕';
    btnDel.addEventListener('click', e=>{
      e.stopPropagation();
      const store2 = getMapsStore();
      if(store2.maps.length<=1){toast('Impossible de supprimer la dernière carte','er');return;}
      if(!confirm('Supprimer "'+map.name+'" ?')) return;
      const wasActive = map.id===currentMapId;
      deleteMap(map.id);
      if(wasActive){const s3=getMapsStore();if(s3.maps.length)loadMap(s3.maps[s3.maps.length-1].id);}
      renderMapsGrid(document.getElementById('maps-search-input').value);
      toast('Carte supprimée','ok');
    });
    actions.appendChild(btnDel);

    card.append(thumb, info, actions);
    if(!isActive) card.addEventListener('click', ()=>{loadMap(map.id);closeMapsManager();toast('Carte chargée : '+map.name,'ok');});
    grid.appendChild(card);
  });
}

