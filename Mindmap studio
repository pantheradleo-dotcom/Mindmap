function fitView(){const vis=nodes.filter(n=>!isHidden(n.id));if(!vis.length){viewX=0;viewY=0;scale=1;render();mmR();return;}let mnX=Infinity,mnY=Infinity,mxX=-Infinity,mxY=-Infinity;vis.forEach(n=>{mnX=Math.min(mnX,n.x-n.width/2);mnY=Math.min(mnY,n.y-n.height/2);mxX=Math.max(mxX,n.x+n.width/2);mxY=Math.max(mxY,n.y+n.height/2);});const pad=80;scale=Math.max(.1,Math.min(.9,(cv.width-pad*2)/(mxX-mnX),(cv.height-pad*2)/(mxY-mnY)));viewX=cv.width/2-((mnX+mxX)/2)*scale;viewY=cv.height/2-((mnY+mxY)/2)*scale;render();mmR();}
function animTo(tx,ty,ts,dur){let t=0;const sx=viewX,sy=viewY,ss=scale;(function step(){t++;const p=1-Math.pow(1-t/dur,3);viewX=sx+(tx-sx)*p;viewY=sy+(ty-sy)*p;scale=ss+(ts-ss)*p;render();mmR();if(t<dur)requestAnimationFrame(step);})();}

