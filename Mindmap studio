// ── MAP LINK PICKER ──────────────────────────────────────────────────
function openMapLinkPicker(nodeId){
  const store=getMapsStore();
  const otherMaps=store.maps.filter(m=>m.id!==currentMapId);
  if(!otherMaps.length){toast('Aucune autre carte disponible','in');return;}
  const existing=document.getElementById('maplink-popup');
  if(existing)existing.remove();
  const pop=document.createElement('div');
  pop.id='maplink-popup';
  pop.style.cssText='position:fixed;background:var(--surf);border:1.5px solid var(--brd);border-radius:10px;padding:8px;z-index:600;box-shadow:var(--shadow2);min-width:200px;max-height:280px;overflow-y:auto;';
  otherMaps.forEach(m=>{
    const item=document.createElement('div');
    item.style.cssText='padding:8px 11px;border-radius:7px;cursor:pointer;font-size:12px;font-weight:500;transition:background .1s;';
    item.textContent=m.name;
    item.addEventListener('mouseover',()=>item.style.background='rgba(91,106,240,.1)');
    item.addEventListener('mouseout',()=>item.style.background='');
    item.addEventListener('click',()=>{
      snap();const n=gn(nodeId);if(n){n.mapLink=m.id;document.getElementById('rp-maplink-label').textContent=m.name;}
      render();pop.remove();toast('Lien carte défini : '+m.name,'ok');
    });
    pop.appendChild(item);
  });
  const rpBtn=document.getElementById('rp-maplink-btn');
  const r=rpBtn.getBoundingClientRect();
  pop.style.top=(r.bottom+4)+'px';pop.style.left=r.left+'px';
  document.body.appendChild(pop);
  setTimeout(()=>document.addEventListener('click',function h(e){if(!pop.contains(e.target)){pop.remove();document.removeEventListener('click',h);}},{once:false}),100);
}
document.getElementById('rp-maplink-btn').addEventListener('click',()=>{if(selId)openMapLinkPicker(selId);});
document.getElementById('rp-maplink-clear').addEventListener('click',()=>{const n=gn(selId);if(n){snap();n.mapLink=null;document.getElementById('rp-maplink-label').textContent='Aucun';render();}});

