// ── GALLERY RENDERING ─────────────────────────────────────────────────────
const CATEGORIES=['Tous',...[...new Set(TEMPLATES.map(t=>t.cat))]];
let activeCat='Tous';

function previewSVG(tpl){
  // Generate a tiny SVG preview based on the template color & structure
  const c=tpl.color;
  const dots=[{x:50,y:50,r:12,fill:c},{x:18,y:24,r:7,fill:c+'cc'},{x:82,y:24,r:7,fill:c+'cc'},{x:18,y:75,r:7,fill:c+'cc'},{x:82,y:75,r:7,fill:c+'cc'}];
  const lines=[[50,50,18,24],[50,50,82,24],[50,50,18,75],[50,50,82,75]];
  let svg=`<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" style="background:transparent">`;
  lines.forEach(([x1,y1,x2,y2])=>{svg+=`<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="${c}" stroke-width="1.5" stroke-opacity="0.5"/>`});
  dots.forEach(d=>{svg+=`<circle cx="${d.x}" cy="${d.y}" r="${d.r}" fill="${d.fill}" fill-opacity="0.85"/>`;});
  svg+=`<text x="50" y="53" text-anchor="middle" font-size="8" font-family="Inter,sans-serif" fill="white" font-weight="600">${tpl.emoji}</text>`;
  svg+='</svg>';
  return svg;
}

function renderGallery(){
  const grid=document.getElementById('tpl-grid');
  grid.innerHTML='';
  const filtered=activeCat==='Tous'?TEMPLATES:TEMPLATES.filter(t=>t.cat===activeCat);
  filtered.forEach(tpl=>{
    const card=document.createElement('div');
    card.className='tpl-card'+(tpl.id==='blank'?' blank':'');
    const badgeColor={Général:'#5b6af0',Stratégie:'#a855f7',Analyse:'#f0a500',Gestion:'#0ea5e9',Créativité:'#f97316',Éducation:'#e85d7a'}[tpl.cat]||'#999';
    card.innerHTML=`
      <div class="tpl-preview">${tpl.id==='blank'?`<div class="tpl-blank-icon">✦</div>`:previewSVG(tpl)}</div>
      <div class="tpl-info">
        <div class="tpl-name">${tpl.name}</div>
        <div class="tpl-desc">${tpl.desc}</div>
        <span class="tpl-badge" style="background:${badgeColor}22;color:${badgeColor};border:1px solid ${badgeColor}44">${tpl.cat}</span>
      </div>`;
    card.addEventListener('click',()=>applyTemplate(tpl));
    grid.appendChild(card);
  });
}

function renderCats(){
  const bar=document.getElementById('tpl-cats');bar.innerHTML='';
  CATEGORIES.forEach(cat=>{const b=document.createElement('button');b.className='tpl-cat'+(activeCat===cat?' on':'');b.textContent=cat;b.addEventListener('click',()=>{activeCat=cat;document.querySelectorAll('.tpl-cat').forEach(x=>x.classList.toggle('on',x.textContent===cat));renderGallery();});bar.appendChild(b);});
}

function openGallery(){document.getElementById('tpl-overlay').classList.add('open');renderCats();renderGallery();}
function closeGallery(){document.getElementById('tpl-overlay').classList.remove('open');}

document.getElementById('tpl-close').addEventListener('click',closeGallery);
document.getElementById('tpl-overlay').addEventListener('click',e=>{if(e.target===document.getElementById('tpl-overlay'))closeGallery();});
document.getElementById('btn-templates').addEventListener('click',openGallery);

function applyTemplate(tpl){
  closeGallery();
  // Ask: apply to current map or create new one?
  const name = prompt('Nom de la carte (laissez vide pour remplacer la carte actuelle) :', tpl.name);
  if(name === null) return; // cancelled
  if(name.trim()) {
    // Create new map with this template
    createNewMap(name.trim(), true);
  } else {
    // Replace current
    snap(); nodes=[]; conns=[];
  }
  const cx=cv.width/2/scale, cy=cv.height/2/scale;
  tpl.build(cx,cy);
  autoLayout(nodes.find(n=>!n.parentId)?.id);
  rebuildTags(); fitView(); snap();
  toast('Template "'+tpl.name+'" chargé !', 'ok');
  render(); mmR();
}

// ── COPY/PASTE ────────────────────────────────────────────────────────────
function copyNodes(){
  const ids=selectedIds.size>0?[...selectedIds]:(selId?[selId]:[]);if(!ids.length)return;
  const allIds=new Set();
  function collect(id){if(allIds.has(id))return;allIds.has(id)||(allIds.add(id),kids(id).forEach(c=>collect(c.id)));}
  ids.forEach(collect);
  clipboard={nodes:nodes.filter(n=>allIds.has(n.id)).map(n=>({...n,tags:[...(n.tags||[])]})),conns:conns.filter(c=>allIds.has(c.s)&&allIds.has(c.t))};
  toast(clipboard.nodes.length+' nœud(s) copié(s)','ok');
}
function pasteNodes(){
  if(!clipboard||!clipboard.nodes.length)return;
  snap();const idMap={};const offset=40+Math.random()*20;
  clipboard.nodes.forEach(n=>{const newId=uid();idMap[n.id]=newId;});
  clipboard.nodes.forEach(n=>{const nn={...n,id:idMap[n.id],parentId:n.parentId?idMap[n.parentId]||null:null,x:n.x+offset,y:n.y+offset,tags:[...(n.tags||[])]};nodes.push(nn);});
  clipboard.conns.forEach(c=>{if(idMap[c.s]&&idMap[c.t])addConn(idMap[c.s],idMap[c.t],c.type);});
  const newIds=clipboard.nodes.map(n=>idMap[n.id]);selId=newIds[0];selectedIds=new Set(newIds);
  render();mmR();posFtb();toast(clipboard.nodes.length+' nœud(s) collé(s)','ok');
}

