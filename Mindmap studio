function isDescendantOf(nodeId, ancestorId) {
  let cur = gn(nodeId);
  while(cur && cur.parentId) {
    if(cur.parentId === ancestorId) return true;
    cur = gn(cur.parentId);
  }
  return false;
}

// ── FOCUS BRANCH HELPERS ────────────────────────────────────────────
function getDescendantIds(rootId){
  const result=new Set();
  // Compute ancestors of rootId to never traverse upward
  const ancestors=new Set();
  let _anc=gn(rootId);
  while(_anc&&_anc.parentId){ancestors.add(_anc.parentId);_anc=gn(_anc.parentId);}
  // BFS: follow kids (parentId) + ALL connections (both directions), skip ancestors
  const visited=new Set([rootId]);
  const queue=[rootId];
  while(queue.length){
    const id=queue.shift();
    // Via parentId hierarchy
    kids(id).forEach(c=>{if(!visited.has(c.id)){visited.add(c.id);result.add(c.id);queue.push(c.id);}});
    // Via connections — both directions, but never go into ancestors
    conns.forEach(c=>{
      let other=null;
      if(c.s===id)other=c.t;
      else if(c.t===id)other=c.s;
      if(other&&!visited.has(other)&&!ancestors.has(other)){
        visited.add(other);result.add(other);queue.push(other);
      }
    });
  }
  return result;
}
function collectBranchIds(rootId){
  const ids=getDescendantIds(rootId);
  ids.add(rootId);
  // Add ancestor chain up to global root for path visibility
  let cur=gn(rootId);
  const seen=new Set([rootId]);
  while(cur){
    if(cur.parentId&&!seen.has(cur.parentId)){seen.add(cur.parentId);ids.add(cur.parentId);cur=gn(cur.parentId);continue;}
    // Fallback: find parent via conns (t→s direction where s is parent)
    const parentConn=conns.find(c=>c.t===cur.id&&!seen.has(c.s));
    if(parentConn){seen.add(parentConn.s);ids.add(parentConn.s);cur=gn(parentConn.s);continue;}
    break;
  }
  return ids;
}
