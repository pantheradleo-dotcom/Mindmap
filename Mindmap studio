      if(Math.hypot(wx-bx,wy-by)<=7){
        const store=getMapsStore();
        if(store.maps.find(m=>m.id===n.mapLink)){loadMap(n.mapLink);toast('Navigation vers carte liée','ok');}
        else{toast('Carte liée introuvable','er');}
        return;
      }
    }
    if(n.url&&Math.hypot(wx-n.x+n.width/2-8,wy-n.y+n.height/2-8)<=7){window.open(n.url,'_blank');return;}
    if(onCollBtn(n,wx,wy)){toggleCollapse(n.id);return;}
    if(onEdge(n,wx,wy)){connFrom=n.id;connMouse={x:wx,y:wy};return;}
    dragId=n.id;dragOX=wx-n.x;dragOY=wy-n.y;
    dragStartX=wx;dragStartY=wy;
    selShapeId=null;selFrameId=null;
    if(e.shiftKey){selectedIds.has(n.id)?selectedIds.delete(n.id):selectedIds.add(n.id);}
    else{if(!selectedIds.has(n.id)){selId=n.id;selectedIds=new Set([n.id]);}}
    selId=n.id;hideShapeFtb();hideFrameFtb();
    // Collect all nodes to drag: selected nodes + all their descendants (branch move)
    multiDragOffsets.clear();
    const dragSet=new Set(selectedIds);
    selectedIds.forEach(sid=>{const desc=getDescendantIds(sid);desc.forEach(d=>dragSet.add(d));});
