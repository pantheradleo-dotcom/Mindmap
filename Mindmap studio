function computeHarmonizedColorMap(mode=colorMode){
  const map=new Map();
  const roots=nodes.filter(n=>!n.parentId);
  if(!roots.length) return map;
  const palette=PAL.length?PAL:PALETTES[0].colors;
  roots.forEach((root,i)=>{
    const base=isColorLocked(root)?branchColor(root):(palette[i%palette.length]||getNextRootColor());
    map.set(root.id,base);
    const walk=(parentId,baseColor,depth)=>{
      const ch=kids(parentId);
      ch.forEach((child,idx)=>{
        const col=isColorLocked(child)?branchColor(child):getBranchColorVariant(baseColor,depth,idx,mode);
        map.set(child.id,col);
        walk(child.id,col,depth+1);
      });
    };
    walk(root.id,base,1);
  });
  return map;
}
