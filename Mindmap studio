function autoLayout(rootId){
  const root=gn(rootId)||nodes.find(n=>!n.parentId);if(!root)return;
  root.x=cv.width/scale/2;root.y=cv.height/scale/2;
  function pl(nid,d,sa,as){const ch=kids(nid);if(!ch.length)return;const r2=180+d*140;const spread=Math.max(as,Math.PI*2/(d===0?1:2)/Math.max(ch.length,.5));ch.forEach((c,i)=>{const a=sa+(spread/ch.length)*(i+.5)-spread/2;c.x=gn(nid).x+Math.cos(a)*r2;c.y=gn(nid).y+Math.sin(a)*r2;pl(c.id,d+1,a,spread/ch.length*1.4);});}
  pl(root.id,0,0,Math.PI*2);
  for(let it=0;it<60;it++){for(let i=0;i<nodes.length;i++){for(let j=i+1;j<nodes.length;j++){const a=nodes[i],b=nodes[j];const dx=b.x-a.x,dy=b.y-a.y,dist=Math.hypot(dx,dy)||1;const minD=(a.width+b.width)/2+50;if(dist<minD){const push=(minD-dist)/2*.6;if(a.parentId){a.x-=(dx/dist)*push;a.y-=(dy/dist)*push;}if(b.parentId){b.x+=(dx/dist)*push;b.y+=(dy/dist)*push;}}}}}
}

