  if(e.button===0&&activeTool==='select'&&!n){
    const hitConn=connAt(wx,wy);
    if(hitConn){selConnId=hitConn.id;selId=null;selShapeId=null;selFrameId=null;selectedIds.clear();hideFtb();hideShapeFtb();hideFrameFtb();render();return;}
  }
  // Deselect conn when clicking elsewhere
  if(selConnId&&!connAt(wx,wy)){selConnId=null;}
  if(e.button===2){
    if(n){ctxId=n.id;selId=n.id;selectedIds=new Set([n.id]);cm.style.display='block';cm.style.left=Math.min(e.clientX,window.innerWidth-200)+'px';cm.style.top=Math.min(e.clientY,window.innerHeight-200)+'px';render();posFtb();}
    else{const conn=connAt(wx,wy);if(conn){selConnId=conn.id;render();showConnMenu(e.clientX,e.clientY,conn.id);}}
