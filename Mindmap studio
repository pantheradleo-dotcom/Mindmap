function getNodeDepth(nodeId){let d=0,cur=gn(nodeId),seen=new Set();while(cur&&cur.parentId&&!seen.has(cur.id)){seen.add(cur.id);cur=gn(cur.parentId);d++;}return d;}
function getRootBranchIds(){return nodes.filter(n=>!n.parentId).map(n=>n.id);}
function getSiblingIndexForNewChild(parentId){return kids(parentId).length;}
function getRootBranchAncestorId(node){
  if(!node) return null;
  let cur=node,seen=new Set();
  while(cur&&!seen.has(cur.id)){
    seen.add(cur.id);
    if(!cur.parentId) return cur.id;
    const p=gn(cur.parentId);
    if(!p) return cur.id;
    if(!p.parentId) return cur.id;
    cur=p;
  }
  return node.id;
}
function getNextRootColor(){const pal=PAL.length?PAL:PALETTES[0].colors;const c=pal[rootColorCursor%pal.length];rootColorCursor=(rootColorCursor+1)%Math.max(1,pal.length);return c;}
function getBranchColorVariant(baseColor, depth, siblingIndex = 0, mode = colorMode) {
  let c=baseColor||PAL[0]||'#5b6af0';
  if(mode===COLOR_MODES.FREE) return c;
  if(mode===COLOR_MODES.MONO_BRANCH){
    c=lighten(c,Math.min(depth*5,16));
    if(siblingIndex%2===1) c=desaturate(c,3);
    return c;
  }
  c=lighten(c,Math.min(depth*9,30));
  c=desaturate(c,Math.min(depth*4,14));
  if(siblingIndex%2===1) c=blend(c,'#ffffff',0.04);
  if(siblingIndex%3===2) c=desaturate(c,5);
  return c;
}
function branchColor(n){
  if(!n) return PAL[0]||'#5b6af0';
  if(previewColorsActive && previewColorMap.has(n.id)) return previewColorMap.get(n.id);
  if(n.colorOverride) return n.colorOverride;
  if(n.color) return n.color;
  if(!n.parentId) return PAL[0]||'#5b6af0';
  const p=gn(n.parentId);
  if(!p) return PAL[getBranchIdx(n)%PAL.length]||PAL[0]||'#5b6af0';
  return getBranchColorVariant(branchColor(p), getNodeDepth(n.id), kids(p.id).findIndex(k=>k.id===n.id), colorMode===COLOR_MODES.FREE?COLOR_MODES.HARMONIZED:colorMode);
}
function onEdge(n,wx,wy){const M=8,dx=Math.abs(wx-n.x),dy=Math.abs(wy-n.y);return dx<=n.width/2+M&&dy<=n.height/2+M&&(dx>=n.width/2-M||dy>=n.height/2-M);}
