function layoutTreeH() {
  attachOrphans();
  const root = nodes.find(n=>!n.parentId); if(!root)return;
  function countLeaves(id){ const ch=kids(id); return ch.length?ch.reduce((s,c)=>s+countLeaves(c.id),0):1; }
  const xGap = 220, yGap = 75;
  // Compute tree height to center it vertically on screen
  const totalLeaves = countLeaves(root.id);
  const treeH = (totalLeaves - 1) * yGap;
  // Place root vertically centered, horizontally on left quarter
  const cx = (cv.width/2 - viewX) / scale;
  const cy = (cv.height/2 - viewY) / scale;
  const rootX = cx - (getMaxDepth(root.id) * xGap) / 2;
  const rootY = cy;
  root.x = rootX; root.y = rootY;
  function place(id, depth, yCenter) {
    const n=gn(id); if(!n)return;
    n.x = rootX + depth * xGap;
    n.y = yCenter;
