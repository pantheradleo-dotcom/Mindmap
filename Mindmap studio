document.getElementById('tpl-save-cur').addEventListener('click',()=>{
  if(!nodes.length){toast('Carte vide — rien à sauvegarder','in');return;}
  const name=prompt('Nom du template :','');
  if(!name||!name.trim())return;
  // Snapshot current nodes/conns
  const snapNodes=nodes.map(n=>({...n,tags:[...(n.tags||[])]}));
  const snapConns=[...conns];
  const newTpl={
    id:'user-'+uid(),
    _user:true,
    cat:'Mes templates',
    name:name.trim(),
    desc:'Template personnalisé',
    color:PAL[0],
    emoji:'⭐',
    // Store nodes/conns as data instead of build function
    _nodes:snapNodes,
    _conns:snapConns,
    build(cx,cy){
      // Compute centroid of original nodes
      const xs=this._nodes.map(n=>n.x),ys=this._nodes.map(n=>n.y);
      const cx0=(Math.min(...xs)+Math.max(...xs))/2;
      const cy0=(Math.min(...ys)+Math.max(...ys))/2;
      const dx=cx-cx0,dy=cy-cy0;
      // ID remapping for fresh nodes
      const idMap={};
      this._nodes.forEach(n=>{idMap[n.id]=uid();});
      this._nodes.forEach(n=>{
        const newN={...n,id:idMap[n.id],parentId:n.parentId?idMap[n.parentId]||null:null,x:n.x+dx,y:n.y+dy,tags:[...(n.tags||[])]};
        nodes.push(newN);
      });
      this._conns.forEach(conn=>{
        if(idMap[conn.s]&&idMap[conn.t])addConn(idMap[conn.s],idMap[conn.t],conn.type||'h');
      });
    }
  };
  const ut=getUserTemplates();
  ut.push(newTpl);
  saveUserTemplates(ut);
  renderGallery();renderCats();
  toast('Template "'+name.trim()+'" sauvegardé ✦','ok');
});

document.getElementById('tpl-export').addEventListener('click',()=>{
  const ut=getUserTemplates();
  if(!ut.length){toast('Aucun template perso à exporter','in');return;}
  const blob=new Blob([JSON.stringify({version:1,userTemplates:ut},null,2)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);
  a.download='mes-templates-'+Date.now()+'.json';a.click();
  toast(ut.length+' template(s) exporté(s)','ok');
});

document.getElementById('tpl-import-btn').addEventListener('click',()=>{
  document.getElementById('tpl-import-file').click();
});
document.getElementById('tpl-import-file').addEventListener('change',e=>{
  const f=e.target.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=ev=>{
    try{
      const data=JSON.parse(ev.target.result);
      const imported=data.userTemplates||data;
      if(!Array.isArray(imported))throw new Error('Format invalide');
      const ut=getUserTemplates();
      let added=0;
      imported.forEach(t=>{
        if(!ut.find(x=>x.id===t.id)){ut.push({...t,_user:true});added++;}
      });
