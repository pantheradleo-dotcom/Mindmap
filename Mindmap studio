// ── AUTO-LAYOUT ───────────────────────────────────────────────────────────
function autoLayout(rootId){
  attachOrphans();
  const root=gn(rootId)||nodes.find(n=>!n.parentId);if(!root)return;
  root.x=(cv.width/2-viewX)/scale;root.y=(cv.height/2-viewY)/scale;
  function countLeaves(id){const ch=kids(id);return ch.length?ch.reduce((s,c)=>s+countLeaves(c.id),0):1;}
  function pl(nid,d,sa,as){
    const ch=kids(nid);if(!ch.length)return;
    const r2=160+d*130;
    const lv=ch.map(c=>countLeaves(c.id));
    const tot=lv.reduce((a,b)=>a+b,0);
    const totalAng=Math.min(Math.PI*2,Math.max(as,tot*0.45));
    let curAng=sa-totalAng/2;
    ch.forEach((c,i)=>{
      const share=(lv[i]/tot)*totalAng;
      const a=curAng+share/2;
      c.x=gn(nid).x+Math.cos(a)*r2;
      c.y=gn(nid).y+Math.sin(a)*r2;
      pl(c.id,d+1,a,share);
      curAng+=share;
    });
  }
  pl(root.id,0,-Math.PI/2,Math.PI*2);
  // Collision relaxation
  for(let it=0;it<80;it++){for(let i=0;i<nodes.length;i++){for(let j=i+1;j<nodes.length;j++){const a=nodes[i],b=nodes[j];const dx=b.x-a.x,dy=b.y-a.y,dist=Math.hypot(dx,dy)||1;const minD=(a.width+b.width)/2+55;if(dist<minD){const push=(minD-dist)/2*.5;if(a.parentId){a.x-=(dx/dist)*push;a.y-=(dy/dist)*push;}if(b.parentId){b.x+=(dx/dist)*push;b.y+=(dy/dist)*push;}}}}}
}

