  }
  if(activeTool==='pan'||spaceDown){panning=true;const r=cwEl().getBoundingClientRect();panSX=e.clientX-r.left-viewX;panSY=e.clientY-HH-viewY;return;}

  // ── Shape creation tools ──
  if(['sticky','rect','ellipse','freetext'].includes(activeTool)&&!n){
    const defaults={sticky:{color:'#fffde7',strokeColor:'#f9a825',w:160,h:120},rect:{color:'#e3f2fd',strokeColor:'#1565c0',w:160,h:80},ellipse:{color:'#f3e5f5',strokeColor:'#6a1b9a',w:160,h:80},freetext:{color:'transparent',strokeColor:isDark?'#e4e8f8':'#1a1d2e',w:160,h:40}};
    const d=defaults[activeTool];
    const ns={id:uid(),type:activeTool,x:wx,y:wy,width:d.w,height:d.h,text:'',color:d.color,strokeColor:d.strokeColor,fontSize:activeTool==='freetext'?16:13,rotation:0};
    shapes.push(ns);selShapeId=ns.id;selId=null;selFrameId=null;selectedIds.clear();hideFtb();
    setTool('select');
    if(activeTool==='freetext'||activeTool==='sticky'){
      // Open inline edit for text shapes immediately
      setTimeout(()=>startShapeEdit(ns.id),50);
    }
    snap();render();return;
  }

  // ── Frame creation tool ──
  if(activeTool==='frame'&&!n){
    creatingFrame=true;frameStart={x:wx,y:wy,ex:wx,ey:wy};
    selId=null;selShapeId=null;selFrameId=null;selectedIds.clear();hideFtb();render();return;
  }

  // ── Shape hit test (before nodes) ──
  if(!n&&activeTool==='select'){
    // Check shape resize handles first
    if(selShapeId){const ss=shapes.find(x=>x.id===selShapeId);if(ss){const rh=getResizeHandle(ss,wx,wy);if(rh){resizingShape=ss.id;resizeHandle=rh;return;}}}
    // Check frame resize handles
    if(selFrameId){const ff=frames.find(x=>x.id===selFrameId);if(ff){const rh=getFrameResizeHandle(ff,wx,wy);if(rh){resizeHandle=rh;return;}}}
    // Check frame label click
    const fl=frameLabelAt(wx,wy);
    if(fl){selFrameId=fl.id;selId=null;selShapeId=null;selectedIds.clear();hideFtb();render();return;}
    // Check shape click
    const sh=shapeAt(wx,wy);
    if(sh){selShapeId=sh.id;selId=null;selFrameId=null;selectedIds.clear();hideFtb();hideFrameFtb();dragShapeId=sh.id;dragShapeOX=wx-sh.x;dragShapeOY=wy-sh.y;render();posShapeFtb();return;}
    // Check frame body click
    const fr=frameAt(wx,wy);
    if(fr){
      // Check if a node is inside
      const nodeInside=nodeAt(wx,wy);
      if(!nodeInside){
        selFrameId=fr.id;selId=null;selShapeId=null;selectedIds.clear();hideFtb();hideShapeFtb();
        dragFrameId=fr.id;dragShapeOX=wx-fr.x;dragShapeOY=wy-fr.y;
        render();posFrameFtb();return;
      }
