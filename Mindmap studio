document.getElementById('maps-import-file').addEventListener('change', e=>{
  const f=e.target.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=ev=>{
    try{
      const data=JSON.parse(ev.target.result);
      if(!data.maps||!Array.isArray(data.maps))throw new Error('Format invalide');
      // Merge with existing maps (avoid duplicate ids)
      const store=getMapsStore();
      let added=0;
      data.maps.forEach(m=>{
        if(!store.maps.find(x=>x.id===m.id)){store.maps.push(m);added++;}
      });
      saveMapsStore(store);
      renderMapsGrid('');
      toast(added+' carte(s) importée(s)','ok');
    }catch(err){toast('Erreur import: '+err.message,'er');}
  };
  r.readAsText(f);e.target.value='';
});

// ── PDF EXPORT ───────────────────────────────────────────────────────
document.getElementById('btn-epdf').addEventListener('click',()=>{
  try{
    if(!window.jspdf){toast('jsPDF non disponible','er');return;}
    const vis=nodes.filter(n=>!isHidden(n.id));
    if(!vis.length){toast('Carte vide','in');return;}
    let mnX=Infinity,mnY=Infinity,mxX=-Infinity,mxY=-Infinity;
    vis.forEach(n=>{mnX=Math.min(mnX,n.x-n.width/2);mnY=Math.min(mnY,n.y-n.height/2);mxX=Math.max(mxX,n.x+n.width/2);mxY=Math.max(mxY,n.y+n.height/2);});
    shapes.forEach(s=>{mnX=Math.min(mnX,s.x-s.width/2);mnY=Math.min(mnY,s.y-s.height/2);mxX=Math.max(mxX,s.x+s.width/2);mxY=Math.max(mxY,s.y+s.height/2);});
    const pad=40,cW=mxX-mnX+pad*2,cH=mxY-mnY+pad*2;
    const A4W=297,A4H=210;
    const scaleX=A4W/cW,scaleY=A4H/cH;
    const sc=Math.min(scaleX,scaleY,1)*0.9;
    const offX=(A4W-(cW*sc))/2-(mnX-pad)*sc;
    const offY=(A4H-(cH*sc))/2-(mnY-pad)*sc;
    const tx=x=>x*sc+offX,ty=y=>y*sc+offY;
    const{jsPDF}=window.jspdf;
    const doc=new jsPDF({orientation:'landscape',unit:'mm',format:'a4'});
    doc.setFillColor(isDark?'#0c0e14':'#edf0f6');
    doc.rect(0,0,A4W,A4H,'F');
    for(const c of conns){
      const s=gn(c.s),t=gn(c.t);
      if(!s||!t||isHidden(c.s)||isHidden(c.t))continue;
      const col=branchColor(s);
      const r2=parseInt(col.slice(1,3),16),g2=parseInt(col.slice(3,5),16),b=parseInt(col.slice(5,7),16);
      doc.setDrawColor(r2,g2,b);
      doc.setLineWidth((s.depth===0?1.2:s.depth===1?0.8:0.5)*sc);
      const sp=nodeBorderPt(s,t.x,t.y),tp=nodeBorderPt(t,s.x,s.y);
      const dx=tp.x-sp.x;
      const pts=[];
      for(let i=0;i<=10;i++){const tt=i/10;const u=1-tt;pts.push({x:u*u*u*sp.x+3*u*u*tt*(sp.x+dx*0.45)+3*u*tt*tt*(tp.x-dx*0.45)+tt*tt*tt*tp.x,y:u*u*u*sp.y+3*u*u*tt*sp.y+3*u*tt*tt*tp.y+tt*tt*tt*tp.y});}
      for(let i=0;i<pts.length-1;i++)doc.line(tx(pts[i].x),ty(pts[i].y),tx(pts[i+1].x),ty(pts[i+1].y));
    }
    vis.forEach(n=>{
      const col=branchColor(n);const isRoot=!n.parentId;
      const r2=parseInt(col.slice(1,3),16),g2=parseInt(col.slice(3,5),16),b=parseInt(col.slice(5,7),16);
      const nx=tx(n.x-n.width/2),ny=ty(n.y-n.height/2),nw=n.width*sc,nh=n.height*sc;
      if(isRoot||n.depth===1){doc.setFillColor(r2,g2,b);}
      else{doc.setFillColor(r2,g2,b,0.15*255);}
      doc.setDrawColor(r2,g2,b);doc.setLineWidth(0.3);
      doc.roundedRect(nx,ny,nw,nh,1.5,1.5,'FD');
      const txtColor=isRoot||n.depth===1?'#ffffff':(isDark?'#e4e8f8':'#1a1d2e');
      const tr=parseInt(txtColor.slice(1,3),16),tg=parseInt(txtColor.slice(3,5),16),tb=parseInt(txtColor.slice(5,7),16);
      doc.setTextColor(tr,tg,tb);
      doc.setFontSize((n.fontSize||13)*sc*2.8);
      const label=(n.emoji?n.emoji+' ':'')+n.text;
      doc.text(label,tx(n.x),ty(n.y),{align:'center',baseline:'middle',maxWidth:nw*0.85});
    });
    doc.save('mindmap-'+Date.now()+'.pdf');
    toast('PDF exporté','ok');
  }catch(err){toast('Erreur PDF: '+err.message,'er');}
});

