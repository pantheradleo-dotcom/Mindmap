let hist=[],histIdx=-1;const MAX_H=80;
function snap(){
  const s=JSON.stringify({nodes:nodes.map(n=>({...n,tags:[...(n.tags||[])]})),conns:[...conns]});
  if(histIdx<hist.length-1)hist=hist.slice(0,histIdx+1);
  hist.push(s);if(hist.length>MAX_H)hist.shift();histIdx=hist.length-1;
  autoSave();
}
function undo(){if(histIdx<=0)return;histIdx--;restore(hist[histIdx]);}
function redo(){if(histIdx>=hist.length-1)return;histIdx++;restore(hist[histIdx]);}
function restore(s){const d=JSON.parse(s);nodes=d.nodes;conns=d.conns;selId=null;selectedIds.clear();hideFtb();rebuildTags();render();mmR();}

function autoSave() {
  if(!currentMapId) return;
  const store = getMapsStore();
  const idx = store.maps.findIndex(m=>m.id===currentMapId);
  const snap = mapSnapshot();
  if(idx>=0) store.maps[idx] = {...store.maps[idx], ...snap};
  else store.maps.push({name:'Nouvelle carte', ...snap});
  store.activeId = currentMapId;
  saveMapsStore(store);
}

function autoLoad() {
  try {
    const store = getMapsStore();
    if(!store.maps.length) return false;
    // Try to load last active map, fallback to most recent
    const activeId = store.activeId;
    const map = store.maps.find(m=>m.id===activeId) || store.maps.sort((a,b)=>b.ts-a.ts)[0];
    if(!map || !map.nodes || !map.nodes.length) return false;
    currentMapId = map.id;
    nodes = map.nodes; conns = map.conns||[];
    if(map.theme) applyTheme(map.theme);
    if(map.palette) applyPalette(map.palette);
    rebuildTags();
    return true;
  } catch { return false; }
}

function loadMap(mapId) {
  const store = getMapsStore();
  const map = store.maps.find(m=>m.id===mapId);
  if(!map) return;
  // Save current map first
  autoSave();
  // Load new map
  currentMapId = map.id;
  nodes = map.nodes||[]; conns = map.conns||[];
  selId=null; selectedIds.clear(); viewX=0; viewY=0; scale=1;
  hideFtb(); hist=[]; histIdx=-1;
  if(map.theme) applyTheme(map.theme);
  if(map.palette) applyPalette(map.palette);
  else render();
  rebuildTags(); fitView();
  store.activeId = currentMapId;
  saveMapsStore(store);
  snap();
}

function createNewMap(name, fromTemplate) {
  const store = getMapsStore();
  // Save current first
  autoSave();
  // Create
  const id = uid();
  const newMap = {
    id, name: name||'Nouvelle carte',
    nodes:[], conns:[], theme: currentTheme, palette: currentPaletteId,
    ts: Date.now()
  };
  store.maps.push(newMap);
  store.activeId = id;
  saveMapsStore(store);
  // Switch to it
  currentMapId = id;
  nodes=[]; conns=[]; selId=null; selectedIds.clear();
  viewX=0; viewY=0; scale=1; hist=[]; histIdx=-1;
  hideFtb();
  if(!fromTemplate) {
    mkNode('Idée centrale', cv.width/2, cv.height/2, 0, null, PAL[0]);
